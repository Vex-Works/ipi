{
  "name": "ipi",
  "version": "0.1.3-beta.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx packages/cli/src/main.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test:unit": "node --import tsx --test packages/core/src/session-store.test.ts packages/tui/src/terminal-sanitize.test.ts",
    "test:bridge": "node --test apps/windows/Ipi.Desktop/bridge-policy.test.mjs apps/windows/Ipi.Desktop/approval-router.test.mjs",
    "test": "npm run typecheck && npm run test:unit && npm run test:bridge"
  },
  "bin": {
    "ipi": "dist/packages/cli/src/main.js"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  }
}
