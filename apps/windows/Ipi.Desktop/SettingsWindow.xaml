          </StackPanel>
          <Button Grid.Column="1" Width="104" Height="32" Style="{StaticResource SettingsGhostButton}" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" Click="AddSkillSource_Click">
            <TextBlock Text="{Binding AddSkillSourceText}" Foreground="{DynamicResource SettingsText}" FontSize="13" />
          </Button>
        </Grid>
        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions><ColumnDefinition Width="300" /><ColumnDefinition Width="18" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <Border Grid.Column="0" Background="{DynamicResource SettingsCard}" BorderBrush="{DynamicResource SettingsLine}" BorderThickness="1" CornerRadius="9" ClipToBounds="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding SkillSources}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button x:Name="SourceRow" Height="78" Style="{StaticResource SettingsListRowButton}" Background="Transparent" Click="SkillSourceButton_Click"
                            AutomationProperties.Name="{Binding Label}" AutomationProperties.HelpText="{Binding Path}" AutomationProperties.ItemStatus="{Binding StateText}">
                      <Border BorderBrush="{DynamicResource SettingsLine}" BorderThickness="0,0,0,1" Padding="14,10" ClipToBounds="True">
                      <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="52" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Label}" Foreground="{DynamicResource SettingsText}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding Path}" Foreground="{DynamicResource SettingsMuted}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,8,8,0" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      IsChecked="{Binding IsEnabled, Mode=OneWay}" Click="SkillSourceToggle_Click"
                                      AutomationProperties.Name="{Binding Label}" AutomationProperties.HelpText="{Binding StateText}" />
                      </Grid>
                      </Border>
                    </Button>
                    <DataTemplate.Triggers>
                      <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter TargetName="SourceRow" Property="Background" Value="{DynamicResource SettingsSidebarSelectedBg}" />
                      </DataTrigger>
                    </DataTemplate.Triggers>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
          <Border Grid.Column="2" Background="{DynamicResource SettingsCard}" BorderBrush="{DynamicResource SettingsLine}" BorderThickness="1" CornerRadius="9" ClipToBounds="True">
            <Grid>
              <Grid.RowDefinitions><RowDefinition Height="44" /><RowDefinition Height="*" /></Grid.RowDefinitions>
              <Border Grid.Row="0" BorderBrush="{DynamicResource SettingsLine}" BorderThickness="0,0,0,1" Padding="18,0">
                <Grid>
                  <TextBlock Text="{Binding SelectedSkillSourceTitle}" Foreground="{DynamicResource SettingsText}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding SkillsSummary}" Foreground="{DynamicResource SettingsMuted}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" />
                </Grid>
              </Border>
              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding SkillItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Height="98" BorderBrush="{DynamicResource SettingsLine}" BorderThickness="0,0,0,1" Padding="18,12" ClipToBounds="True">
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="60" /></Grid.ColumnDefinitions>
                          <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,18,0">
                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource SettingsText}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding StateText}" Foreground="{DynamicResource SettingsMuted}" FontSize="11" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" TextWrapping="Wrap" Height="34" ClipToBounds="True" Margin="0,7,0,0" />
                          </StackPanel>
                          <ToggleButton Grid.Column="1" Style="{StaticResource SettingsToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        IsChecked="{Binding IsEnabled, Mode=OneWay}" IsEnabled="{Binding SourceEnabled}" Click="SkillToggle_Click"
                                        AutomationProperties.Name="{Binding Title}" AutomationProperties.HelpText="{Binding StateText}" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>
      </Grid>

      <Grid Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Visibility="{Binding PluginPackagesPageVisibility}" Margin="52,44,62,36">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,20">
          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
              <local:LucideIcon Icon="plug" Size="18" Stroke="{DynamicResource SettingsMuted}" Margin="0,1,12,0" />
              <TextBlock Text="{Binding PluginPackagesTitle}" Foreground="{DynamicResource SettingsText}" FontSize="18" FontWeight="Medium" />
              <TextBlock Text="{Binding PluginPackagesSummary}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" Margin="14,4,0,0" />
            </StackPanel>
            <TextBlock Text="{Binding PluginPackagesDescription}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" TextWrapping="Wrap" />
            <TextBlock Text="{Binding PluginPackagesSettingsPath}" Foreground="{DynamicResource SettingsMuted}" FontSize="11" FontFamily="{DynamicResource IpiCodeFontFamily}" TextTrimming="CharacterEllipsis" Margin="0,8,0,0" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
            <Button Width="82" Height="32" Style="{StaticResource SettingsGhostButton}" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" Click="AddPackageOpen_Click" IsEnabled="{Binding PackageActionButtonEnabled}" Margin="0,0,8,0">
              <TextBlock Text="{Binding PackageAddButtonText}" Foreground="{DynamicResource SettingsText}" FontSize="13" />
            </Button>
            <Button Width="92" Height="32" Style="{StaticResource SettingsGhostButton}" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" Click="UpdatePackage_Click" IsEnabled="{Binding SelectedPackageActionButtonEnabled}" Margin="0,0,8,0">
              <TextBlock Text="{Binding PackageUpdateButtonText}" Foreground="{DynamicResource SettingsText}" FontSize="13" />
            </Button>
            <Button Width="108" Height="32" Style="{StaticResource SettingsGhostButton}" Background="#18FF4D4D" BorderBrush="#33FF4D4D" BorderThickness="1" Click="RemovePackage_Click" IsEnabled="{Binding SelectedPackageActionButtonEnabled}" Margin="0,0,8,0">
              <TextBlock Text="{Binding PackageRemoveButtonText}" Foreground="#D94A45" FontSize="13" />
            </Button>
            <Button Width="92" Height="32" Style="{StaticResource SettingsGhostButton}" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" Click="RefreshPackages_Click" IsEnabled="{Binding PackageActionButtonEnabled}">
              <TextBlock Text="{Binding RefreshPackagesText}" Foreground="{DynamicResource SettingsText}" FontSize="13" />
            </Button>
          </StackPanel>
        </Grid>
        <Border Grid.Row="1" Background="{DynamicResource SettingsCard}" BorderBrush="{DynamicResource SettingsLine}" BorderThickness="1" CornerRadius="9" Padding="14,12" Margin="0,0,0,14" Visibility="{Binding PackageAddVisibility}">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="130" /><ColumnDefinition Width="*" /><ColumnDefinition Width="138" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <TextBlock x:Name="PackageInstallSourceLabel" Text="{Binding PackageInstallSourceLabel}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding PackageNewSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" Foreground="{DynamicResource SettingsText}" CaretBrush="{DynamicResource SettingsCaret}" SelectionBrush="{DynamicResource SettingsSelection}" Padding="10,0" VerticalContentAlignment="Center" FontFamily="{DynamicResource IpiCodeFontFamily}" ToolTip="{Binding PackageSourcePlaceholder}" AutomationProperties.LabeledBy="{Binding ElementName=PackageInstallSourceLabel}" />
            <Border Grid.Column="2" Height="32" Margin="10,0,0,0" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" CornerRadius="7" Padding="3" ToolTip="{Binding PackageInstallScopeDetail}">
              <TextBlock Text="{Binding PackageGlobalScopeText}" Foreground="{DynamicResource SettingsText}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Button Grid.Column="3" Width="76" Height="32" Style="{StaticResource SettingsGhostButton}" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" Click="AddPackageConfirm_Click" IsEnabled="{Binding PackageActionButtonEnabled}" Margin="10,0,0,0">
              <TextBlock Text="{Binding PackageAddButtonText}" Foreground="{DynamicResource SettingsText}" FontSize="13" />
            </Button>
            <Button Grid.Column="4" Width="76" Height="32" Style="{StaticResource SettingsGhostButton}" Background="Transparent" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" Click="AddPackageCancel_Click" IsEnabled="{Binding PackageActionButtonEnabled}" Margin="8,0,0,0">
              <TextBlock Text="{Binding PackageCancelButtonText}" Foreground="{DynamicResource SettingsMuted}" FontSize="13" />
            </Button>
          </Grid>
        </Border>
        <TextBlock Grid.Row="1" Text="{Binding PackageActionStatus}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" Margin="0,-10,0,12" VerticalAlignment="Bottom" Visibility="{Binding PackageActionStatusVisibility}" AutomationProperties.Name="Package status" AutomationProperties.LiveSetting="Polite" />
        <Grid Grid.Row="2">
          <Grid.ColumnDefinitions><ColumnDefinition Width="320" /><ColumnDefinition Width="18" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <Border Grid.Column="0" Background="{DynamicResource SettingsCard}" BorderBrush="{DynamicResource SettingsLine}" BorderThickness="1" CornerRadius="9" ClipToBounds="True">
            <Grid>
              <TextBlock Text="{Binding PluginPackagesEmptyText}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding PluginPackagesEmptyVisibility}" />
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="{Binding PluginPackagesDetailVisibility}">
                <ItemsControl ItemsSource="{Binding SettingsPluginPackages}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button x:Name="PackageRow" Height="84" Style="{StaticResource SettingsListRowButton}" Background="Transparent" Click="SettingsPluginPackageButton_Click"
                              AutomationProperties.Name="{Binding Title}" AutomationProperties.HelpText="{Binding Source}" AutomationProperties.ItemStatus="{Binding StatusText}">
                        <Border BorderBrush="{DynamicResource SettingsLine}" BorderThickness="0,0,0,1" Padding="14,10" ClipToBounds="True">
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="52" /></Grid.ColumnDefinitions>
                          <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource SettingsText}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Source}" Foreground="{DynamicResource SettingsMuted}" FontSize="11" FontFamily="{DynamicResource IpiCodeFontFamily}" TextTrimming="CharacterEllipsis" Margin="0,6,8,0" />
                            <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource SettingsMuted}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,4,8,0" />
                          </StackPanel>
                          <ToggleButton Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        IsChecked="{Binding Disabled, Converter={StaticResource InverseBoolean}, Mode=OneWay}" Click="SettingsPluginPackageToggle_Click"
                                        AutomationProperties.Name="{Binding Title}" AutomationProperties.HelpText="{Binding StatusText}">
                            <ToggleButton.Style>
                              <Style TargetType="ToggleButton" BasedOn="{StaticResource SettingsToggleSwitch}">
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding Scope}" Value="project">
                                    <Setter Property="IsEnabled" Value="False" />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </ToggleButton.Style>
                          </ToggleButton>
                        </Grid>
                        </Border>
                      </Button>
                      <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                          <Setter TargetName="PackageRow" Property="Background" Value="{DynamicResource SettingsSidebarSelectedBg}" />
                        </DataTrigger>
                      </DataTemplate.Triggers>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>
          <Border Grid.Column="2" Background="{DynamicResource SettingsCard}" BorderBrush="{DynamicResource SettingsLine}" BorderThickness="1" CornerRadius="9" ClipToBounds="True" Visibility="{Binding PluginPackagesDetailVisibility}">
            <Grid>
              <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
              <Border Grid.Row="0" BorderBrush="{DynamicResource SettingsLine}" BorderThickness="0,0,0,1" Padding="18,16">
                <StackPanel>
                  <TextBlock Text="{Binding SelectedPluginPackageTitle}" Foreground="{DynamicResource SettingsText}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding SelectedPluginPackageSource}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" TextTrimming="CharacterEllipsis" Margin="0,7,0,0" />
                  <UniformGrid Columns="2" Margin="0,16,0,0">
                    <StackPanel Margin="0,0,16,10"><TextBlock Text="{Binding PackageStatusLabel}" Foreground="{DynamicResource SettingsMuted}" FontSize="11" /><TextBlock Text="{Binding SelectedPluginPackageStatus}" Foreground="{DynamicResource SettingsText}" FontSize="13" Margin="0,4,0,0" /></StackPanel>
                    <StackPanel Margin="0,0,16,10"><TextBlock Text="{Binding PackageVersionLabel}" Foreground="{DynamicResource SettingsMuted}" FontSize="11" /><TextBlock Text="{Binding SelectedPluginPackageVersion}" Foreground="{DynamicResource SettingsText}" FontSize="13" Margin="0,4,0,0" /></StackPanel>
                    <StackPanel Margin="0,0,16,10"><TextBlock Text="{Binding PackageResourcesLabel}" Foreground="{DynamicResource SettingsMuted}" FontSize="11" /><TextBlock Text="{Binding SelectedPluginPackageResources}" Foreground="{DynamicResource SettingsText}" FontSize="13" Margin="0,4,0,0" /></StackPanel>
                    <StackPanel Margin="0,0,16,10"><TextBlock Text="{Binding PackageScopeLabel}" Foreground="{DynamicResource SettingsMuted}" FontSize="11" /><TextBlock Text="{Binding SelectedPluginPackageScope}" Foreground="{DynamicResource SettingsText}" FontSize="13" Margin="0,4,0,0" /></StackPanel>
                  </UniformGrid>
                  <TextBlock Text="{Binding SelectedPluginPackagePath}" Foreground="{DynamicResource SettingsMuted}" FontSize="11" FontFamily="{DynamicResource IpiCodeFontFamily}" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
              </Border>
              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding SettingsPluginResourceGroups}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Margin="18,16,18,4">
                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource SettingsText}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding Items}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border BorderBrush="{DynamicResource SettingsLine}" BorderThickness="0,0,0,1" Padding="0,8">
                                <Grid>
                                  <Grid.ColumnDefinitions><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                  <TextBlock Text="{Binding Name}" Foreground="{DynamicResource SettingsText}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                  <TextBlock Grid.Column="1" Text="{Binding Path}" Foreground="{DynamicResource SettingsMuted}" FontSize="11" FontFamily="{DynamicResource IpiCodeFontFamily}" TextTrimming="CharacterEllipsis" />
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>
      </Grid>

      <Grid Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Visibility="{Binding StoragePathsPageVisibility}" Margin="52,44,62,36">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
          <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <local:LucideIcon Icon="folder" Size="18" Stroke="{DynamicResource SettingsMuted}" Margin="0,1,12,0" />
            <TextBlock Text="{Binding StoragePathsTitle}" Foreground="{DynamicResource SettingsText}" FontSize="18" FontWeight="Medium" />
          </StackPanel>
          <TextBlock Text="{Binding StoragePathsDescription}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" TextWrapping="Wrap" />
          <TextBlock Text="{Binding StorageConfigPathText}" Foreground="{DynamicResource SettingsDim}" FontSize="11" FontFamily="{DynamicResource IpiCodeFontFamily}" TextTrimming="CharacterEllipsis" Margin="0,10,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource SettingsCard}" BorderBrush="{DynamicResource SettingsLine}" BorderThickness="1" CornerRadius="9" Padding="22,20">
          <StackPanel>
            <TextBlock Text="{Binding AppDataDirTitle}" Foreground="{DynamicResource SettingsText}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Text="{Binding AppDataDirDescription}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,10" />
            <Grid Margin="0,0,0,22">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="92" /><ColumnDefinition Width="82" /></Grid.ColumnDefinitions>
              <TextBox Grid.Column="0" Text="{Binding AppDataDirOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="34" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" Foreground="{DynamicResource SettingsText}" CaretBrush="{DynamicResource SettingsCaret}" SelectionBrush="{DynamicResource SettingsSelection}" Padding="10,0" VerticalContentAlignment="Center" FontFamily="{DynamicResource IpiCodeFontFamily}" ToolTip="{Binding EffectiveAppDataDir}" />
              <Button Grid.Column="1" Margin="10,0,0,0" Height="34" Style="{StaticResource SettingsGhostButton}" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" Click="BrowseAppDataDir_Click"><TextBlock Text="{Binding BrowseText}" Foreground="{DynamicResource SettingsText}" FontSize="12" /></Button>
              <Button Grid.Column="2" Margin="10,0,0,0" Height="34" Style="{StaticResource SettingsGhostButton}" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" Click="ResetAppDataDir_Click"><TextBlock Text="{Binding RestoreDefaultText}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" /></Button>
            </Grid>

            <TextBlock Text="{Binding LocalAppDataDirTitle}" Foreground="{DynamicResource SettingsText}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Text="{Binding LocalAppDataDirDescription}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,10" />
            <Grid Margin="0,0,0,22">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="92" /><ColumnDefinition Width="82" /></Grid.ColumnDefinitions>
              <TextBox Grid.Column="0" Text="{Binding LocalAppDataDirOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="34" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" Foreground="{DynamicResource SettingsText}" CaretBrush="{DynamicResource SettingsCaret}" SelectionBrush="{DynamicResource SettingsSelection}" Padding="10,0" VerticalContentAlignment="Center" FontFamily="{DynamicResource IpiCodeFontFamily}" ToolTip="{Binding EffectiveLocalAppDataDir}" />
              <Button Grid.Column="1" Margin="10,0,0,0" Height="34" Style="{StaticResource SettingsGhostButton}" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" Click="BrowseLocalAppDataDir_Click"><TextBlock Text="{Binding BrowseText}" Foreground="{DynamicResource SettingsText}" FontSize="12" /></Button>
              <Button Grid.Column="2" Margin="10,0,0,0" Height="34" Style="{StaticResource SettingsGhostButton}" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" Click="ResetLocalAppDataDir_Click"><TextBlock Text="{Binding RestoreDefaultText}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" /></Button>
            </Grid>

            <Border Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" CornerRadius="7" Padding="12,10" Margin="0,0,0,16">
              <TextBlock Text="{Binding StorageRestartNotice}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" TextWrapping="Wrap" />
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <TextBlock Text="{Binding StorageStatus}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" VerticalAlignment="Center" Margin="0,0,14,0" Visibility="{Binding StorageStatusVisibility}" AutomationProperties.Name="Storage status" AutomationProperties.LiveSetting="Polite" />
              <Button Width="112" Height="34" Style="{StaticResource SettingsGhostButton}" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" Click="SaveStoragePaths_Click"><TextBlock Text="{Binding SaveStoragePathsText}" Foreground="{DynamicResource SettingsText}" FontSize="13" /></Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>

      <Grid Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Visibility="{Binding RuntimeDiagnosticsPageVisibility}" Margin="52,44,62,36">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
              <local:LucideIcon Icon="terminal-square" Size="18" Stroke="{DynamicResource SettingsMuted}" Margin="0,1,12,0" />
              <TextBlock Text="{Binding RuntimeDiagnosticsTitle}" Foreground="{DynamicResource SettingsText}" FontSize="18" FontWeight="Medium" />
              <TextBlock Text="{Binding RuntimeDiagnosticsSummary}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" Margin="14,4,0,0" />
            </StackPanel>
            <TextBlock Text="{Binding RuntimeDiagnosticsDescription}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" TextWrapping="Wrap" />
          </StackPanel>
          <Button Grid.Column="1" Width="92" Height="32" Style="{StaticResource SettingsGhostButton}" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" Click="RefreshDiagnostics_Click">
            <TextBlock Text="{Binding RefreshDiagnosticsText}" Foreground="{DynamicResource SettingsText}" FontSize="13" />
          </Button>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource SettingsCard}" BorderBrush="{DynamicResource SettingsLine}" BorderThickness="1" CornerRadius="9" ClipToBounds="True">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding RuntimeDiagnostics}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="{DynamicResource SettingsLine}" BorderThickness="0,0,0,1" Padding="18,14">
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="74" /><ColumnDefinition Width="220" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <Border Width="52" Height="24" CornerRadius="12" Background="{DynamicResource SettingsControlBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <TextBlock Text="{Binding Badge}" Foreground="{DynamicResource SettingsMuted}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <TextBlock Grid.Column="1" Text="{Binding Title}" Foreground="{DynamicResource SettingsText}" FontSize="14" FontWeight="Medium" TextTrimming="CharacterEllipsis" Margin="0,2,18,0" />
                      <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" TextWrapping="Wrap" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
      </Grid>

      <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource SettingsFooterBg}" BorderBrush="{DynamicResource SettingsLine}" BorderThickness="0,1,0,0" Padding="52,0,62,0" Visibility="{Binding AppearancePageVisibility}">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="280" /><ColumnDefinition Width="48" /></Grid.ColumnDefinitions>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding WindowTransparencyTitle}" Foreground="{DynamicResource SettingsText}" FontSize="14" FontWeight="Medium" />
            <TextBlock Text="{Binding WindowTransparencyDescription}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" Margin="0,6,0,0" />
          </StackPanel>
          <Slider Grid.Column="1" Minimum="0" Maximum="70" Value="{Binding WindowTransparency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
          <TextBlock Grid.Column="2" Text="{Binding WindowTransparencyLabel}" Foreground="{DynamicResource SettingsMuted}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
