              <ImageBrush ImageSource="Assets/Brand/export/black/ipi-all-black.png" Stretch="Uniform" />
            </Rectangle.OpacityMask>
          </Rectangle>
        </Grid>
        <TextBlock Text="{Binding PanelSubtitle}" Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,12,0,0" TextAlignment="Center" TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Grid.Row="2" MaxWidth="1580" HorizontalAlignment="Stretch" Margin="0,0,0,0"
                  Visibility="{Binding IsComposerVisible, Converter={StaticResource BoolToVisibility}}">
