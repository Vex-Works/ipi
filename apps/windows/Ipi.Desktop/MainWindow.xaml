          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="1" Margin="0,12,0,18" ClipToBounds="True">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="38" /><ColumnDefinition Width="14" /></Grid.ColumnDefinitions>
        <ListBox x:Name="ChatItemsControl" Grid.Column="0" ItemsSource="{Binding ContentRows}" Margin="18,0,8,0" Background="Transparent" BorderThickness="0" Padding="0" Focusable="False" ClipToBounds="True" ScrollViewer.VerticalScrollBarVisibility="Hidden" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False" VirtualizingPanel.IsVirtualizing="False" VirtualizingPanel.VirtualizationMode="Standard" VirtualizingPanel.ScrollUnit="Pixel" Loaded="ChatItemsControl_Loaded" ScrollViewer.ScrollChanged="ChatScrollViewer_ScrollChanged">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Focusable" Value="False" />
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="BorderThickness" Value="0" />
              <Setter Property="Padding" Value="0" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter />
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ListBox.ItemContainerStyle>
          <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="{Binding RowMargin}">
                  <Grid Visibility="{Binding MessageVisibility}">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="{Binding BadgeColumnWidth}" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Badge}" Foreground="{DynamicResource TextDim}" FontSize="11" FontWeight="Medium">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility" Value="Visible" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Badge}" Value="user">
                              <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Badge}" Value="assistant">
                              <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Badge}" Value="thinking">
                              <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <Grid x:Name="MessageHoverRegion" Grid.Column="1" Margin="{Binding ChatContentMargin}" Background="Transparent">
                      <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="{Binding ActionColumnWidth}" /></Grid.ColumnDefinitions>
                      <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="{Binding AssistantHeaderText}" Visibility="{Binding AssistantHeaderVisibility}" Foreground="{DynamicResource TextDim}" FontSize="12" FontWeight="Medium" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding AttachmentItems}" Visibility="{Binding AttachmentsVisibility}" HorizontalAlignment="Right" Margin="0,0,0,7">
                          <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <StaticResource ResourceKey="ChatAttachmentPreviewTemplate" />
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border>
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="MaxWidth" Value="9999" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="CornerRadius" Value="0" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding Badge}" Value="user">
                                <Setter Property="HorizontalAlignment" Value="Right" />
                                <Setter Property="MaxWidth" Value="590" />
                                <Setter Property="MinHeight" Value="44" />
                                <Setter Property="Padding" Value="16,10" />
                                <Setter Property="Background" Value="{DynamicResource UserBubbleBg}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource UserBubbleBorder}" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="CornerRadius" Value="11" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center">
                          <local:SelectableAssistantMessageBox Lines="{Binding AssistantLineItems}" Visibility="{Binding AssistantMessageTextVisibility}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Regular" SelectionBrush="{DynamicResource SelectionBrush}" CaretBrush="{DynamicResource CaretBrush}" LinkClicked="MessageInlineLink_Click" />
                          <StackPanel Visibility="{Binding PlainMessageTextVisibility}">
                            <TextBox Text="{Binding DisplayTitle, Mode=OneWay}" Style="{StaticResource ChatSelectableTextBox}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Regular" VerticalContentAlignment="Center" />
                            <TextBox Text="{Binding DisplayDetail, Mode=OneWay}" Visibility="{Binding DetailVisibility}" Style="{StaticResource ChatSelectableTextBox}" Foreground="{DynamicResource TextDim}" FontSize="12" FontWeight="Regular" Margin="0,3,0,0" VerticalContentAlignment="Center" />
                          </StackPanel>
                        </StackPanel>
                        </Border>
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="4,0,0,0">
                        <StackPanel.Style>
                          <Style TargetType="StackPanel">
                            <Setter Property="Opacity" Value="0" />
                            <Setter Property="IsHitTestVisible" Value="False" />
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding CanUseAsSideContext}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                              </DataTrigger>
                              <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                  <Condition Binding="{Binding CanUseAsSideContext}" Value="True" />
                                  <Condition Binding="{Binding IsMouseOver, ElementName=MessageHoverRegion}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="IsHitTestVisible" Value="True" />
                              </MultiDataTrigger>
                              <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                  <Condition Binding="{Binding CanUseAsSideContext}" Value="True" />
                                  <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=MessageHoverRegion}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="IsHitTestVisible" Value="True" />
                              </MultiDataTrigger>
                            </Style.Triggers>
                          </Style>
                        </StackPanel.Style>
                        <Button Style="{StaticResource GhostButton}" Click="MessageAddToConversation_Click" Width="24" Height="20" Padding="0" Margin="0,0,2,0" Visibility="{Binding SideContextActionVisibility}" ToolTip="{Binding DataContext.AddToConversationText, RelativeSource={RelativeSource AncestorType=Window}}">
                          <local:LucideIcon Icon="message-square" Size="11" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" />
                        </Button>
                        <Button Style="{StaticResource GhostButton}" Click="MessageAskInSideChat_Click" Width="24" Height="20" Padding="0" Visibility="{Binding SideContextActionVisibility}" ToolTip="{Binding DataContext.AskInSideChatText, RelativeSource={RelativeSource AncestorType=Window}}">
                          <local:LucideIcon Icon="plus" Size="11" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" />
                        </Button>
                      </StackPanel>
                      <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,2,0" Visibility="{Binding UserMessageActionsVisibility}">
                        <StackPanel.Style>
                          <Style TargetType="StackPanel">
                            <Setter Property="Opacity" Value="0" />
                            <Setter Property="IsHitTestVisible" Value="False" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsMouseOver, ElementName=MessageHoverRegion}" Value="True">
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="IsHitTestVisible" Value="True" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=MessageHoverRegion}" Value="True">
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="IsHitTestVisible" Value="True" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </StackPanel.Style>
                        <Button Style="{StaticResource MessageActionButton}" Click="MessageCopy_Click" Margin="0,0,8,0" ToolTip="{Binding DataContext.CopyMessageText, RelativeSource={RelativeSource AncestorType=Window}}">
                          <StackPanel Orientation="Horizontal">
                            <local:LucideIcon Icon="copy" Size="12" Stroke="{DynamicResource TextDim}" Margin="0,0,5,0" />
                            <TextBlock Text="{Binding DataContext.CopyMessageText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource TextDim}" FontSize="12" />
                          </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MessageActionButton}" Click="MessageEditFromHere_Click" Margin="0,0,8,0" ToolTip="{Binding DataContext.EditFromHereText, RelativeSource={RelativeSource AncestorType=Window}}">
                          <StackPanel Orientation="Horizontal">
                            <local:LucideIcon Icon="corner-down-right" Size="12" Stroke="{DynamicResource TextMuted}" Margin="0,0,5,0" />
                            <TextBlock Text="{Binding DataContext.EditFromHereText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource TextMuted}" FontSize="12" />
                          </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MessageActionButton}" Click="MessageNewSession_Click" ToolTip="{Binding DataContext.NewSessionFromHereText, RelativeSource={RelativeSource AncestorType=Window}}">
                          <StackPanel Orientation="Horizontal">
                            <local:LucideIcon Icon="git-branch" Size="12" Stroke="{DynamicResource TextDim}" Margin="0,0,5,0" />
                            <TextBlock Text="{Binding DataContext.NewSessionFromHereText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource TextDim}" FontSize="12" />
                          </StackPanel>
                        </Button>
                      </StackPanel>
                    </Grid>
                  </Grid>

                  <Grid Visibility="{Binding UsageVisibility}" Margin="44,-4,0,0">
                    <StackPanel Orientation="Horizontal" Opacity="0.56">
                      <TextBlock Text="{Binding Badge}" Foreground="{DynamicResource TextDim}" FontSize="10.5" FontWeight="Regular" Margin="0,0,7,0" />
                      <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextDim}" FontSize="10.5" FontWeight="Regular" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Grid>

                  <Expander Visibility="{Binding ExpandableVisibility}" IsExpanded="False" Margin="44,0,0,0">
                    <Expander.Header>
                      <Border Height="32" BorderThickness="1" CornerRadius="9" Padding="13,0" MinWidth="520">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource FeedbackSoftBg}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource PopupBorder}" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding Kind}" Value="tool">
                                <Setter Property="Background" Value="{DynamicResource FeedbackRowBg}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource FeedbackRowBorder}" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                          <TextBlock Text="{Binding Badge}" FontSize="12" FontWeight="SemiBold" FontFamily="{DynamicResource IpiCodeFontFamily}" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock.Style>
                              <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextDim}" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding Kind}" Value="tool"><Setter Property="Foreground" Value="{DynamicResource FeedbackAccent}" /></DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </TextBlock.Style>
                          </TextBlock>
                          <TextBlock Grid.Column="1" Text="{Binding Title}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextDim}" FontSize="12" FontWeight="Regular" FontFamily="{DynamicResource IpiCodeFontFamily}" VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </Expander.Header>
                    <Border Background="{DynamicResource FeedbackSoftBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="9" Padding="12,10" Margin="0,7,0,0">
                      <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}" FontSize="12" FontWeight="Regular" FontFamily="{DynamicResource IpiCodeFontFamily}" LineHeight="18" />
                    </Border>
                  </Expander>
                </Grid>
              </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Column="1"
              Background="Transparent"
              Margin="0,42,0,42"
              HorizontalAlignment="Center"
              PreviewMouseWheel="ChatRail_MouseWheel"
              PreviewMouseLeftButtonDown="ChatRail_MouseLeftButtonDown"
              PreviewMouseMove="ChatRail_MouseMove"
              PreviewMouseLeftButtonUp="ChatRail_MouseLeftButtonUp">
          <Grid Width="30" ClipToBounds="True">
            <Grid.OpacityMask>
              <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#00FFFFFF" Offset="0" />
                <GradientStop Color="#FFFFFFFF" Offset="0.07" />
                <GradientStop Color="#FFFFFFFF" Offset="0.93" />
                <GradientStop Color="#00FFFFFF" Offset="1" />
              </LinearGradientBrush>
            </Grid.OpacityMask>
            <ScrollViewer x:Name="ChatMarkerScrollViewer" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" Background="Transparent" CanContentScroll="False" PanningMode="VerticalOnly">
              <Grid MinHeight="{Binding ActualHeight, ElementName=ChatMarkerScrollViewer}">
                <ItemsControl ItemsSource="{Binding ChatMarkers}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,18,0,18">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button x:Name="MarkerButton" Style="{StaticResource GhostButton}" Click="ChatMarker_Click" MouseEnter="ChatMarker_MouseEnter" MouseLeave="ChatMarker_MouseLeave" Width="46" Height="{Binding SlotHeight}" Padding="0" Margin="0" HorizontalContentAlignment="Center" ToolTipService.InitialShowDelay="120" ToolTipService.ShowDuration="9000" ToolTipService.Placement="Left">
                      <Button.ToolTip>
                        <ToolTip Background="Transparent" BorderThickness="0" Padding="0" HasDropShadow="False">
                          <Border Width="360" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="13" Padding="14,12" Cursor="Hand" MouseLeftButtonUp="ChatMarkerPreview_MouseLeftButtonUp">
                            <StackPanel>
                              <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Medium" TextWrapping="Wrap" MaxHeight="44" />
                              <TextBlock Text="{Binding NumberText}" Foreground="{DynamicResource TextDim}" FontSize="11" Margin="0,8,0,0" />
                            </StackPanel>
                          </Border>
                        </ToolTip>
                      </Button.ToolTip>
                      <Border Height="1.6" Width="{Binding VisualWidth}" CornerRadius="0.8" Background="{Binding VisualBrush}" Opacity="{Binding VisualOpacity}" HorizontalAlignment="Center" />
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </ScrollViewer>
          </Grid>
        </Grid>

        <Grid x:Name="ChatExternalScrollHost"
              Grid.Column="2"
              Width="16"
              Margin="0,18,0,18"
              Background="Transparent"
              PreviewMouseLeftButtonDown="ChatExternalScrollHost_MouseLeftButtonDown"
              PreviewMouseMove="ChatExternalScrollHost_MouseMove"
              PreviewMouseLeftButtonUp="ChatExternalScrollHost_MouseLeftButtonUp">
          <Border x:Name="ChatExternalScrollThumb"
                  Width="4"
                  Height="42"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top"
                  Background="{DynamicResource ChatScrollThumb}"
                  CornerRadius="2"
                  Opacity="0.52" />
        </Grid>
      </Grid>

      <ItemsControl Grid.Row="2" ItemsSource="{Binding ToolApprovalRequests}" MaxWidth="1060" HorizontalAlignment="Stretch" Margin="40,0,40,10"
                    AutomationProperties.Name="Tool approval requests" AutomationProperties.LiveSetting="Assertive">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{DynamicResource ComposerBg}" BorderBrush="#6D8DFF" BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,8">
              <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Text="{Binding RequestLabel}" Foreground="{DynamicResource TextDim}" FontSize="11" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Intent}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource TextMuted}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,5,24,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                  <Button Style="{StaticResource ToolbarButton}" Click="ToolApprovalDeny_Click"><TextBlock Text="{Binding DenyText}" Foreground="{DynamicResource TextMuted}" FontSize="12" /></Button>
                  <Button Style="{StaticResource ToolbarButton}" Click="ToolApprovalAlwaysAllow_Click"><TextBlock Text="{Binding AlwaysAllowText}" Foreground="{DynamicResource TextMuted}" FontSize="12" /></Button>
                  <Button Style="{StaticResource ToolbarButton}" Click="ToolApprovalApprove_Click"><TextBlock Text="{Binding AllowText}" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold" /></Button>
                </StackPanel>
                <Border Grid.Row="1" Grid.ColumnSpan="2" Height="34" Background="{DynamicResource RowBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="9" Margin="0,12,0,0" Padding="10,0">
                  <Grid>
                    <TextBlock Text="{Binding GuidancePlaceholder}" Visibility="{Binding GuidancePlaceholderVisibility}" Foreground="{DynamicResource TextDim}" FontSize="12" VerticalAlignment="Center" IsHitTestVisible="False" />
                    <TextBox Text="{Binding Guidance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}" FontSize="12" VerticalContentAlignment="Center" />
                  </Grid>
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <StackPanel Grid.Row="3" MaxWidth="1580" HorizontalAlignment="Stretch" Margin="0,0,0,0">
        <Border Background="{DynamicResource ComposerBg}" BorderBrush="{DynamicResource ComposerBorder}" BorderThickness="1" CornerRadius="8" Padding="8,4" MaxWidth="1580" MinHeight="46" HorizontalAlignment="Stretch" Margin="0,0,0,0">
        <Grid VerticalAlignment="Center">
          <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="38" /><RowDefinition Height="0" /></Grid.RowDefinitions>
          <ItemsControl ItemsSource="{Binding Attachments}" Margin="0,0,0,8">
            <ItemsControl.Style>
              <Style TargetType="ItemsControl">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <Trigger Property="HasItems" Value="False"><Setter Property="Visibility" Value="Collapsed" /></Trigger>
                </Style.Triggers>
              </Style>
            </ItemsControl.Style>
            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <StaticResource ResourceKey="AttachmentTemplate" />
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Grid Grid.Row="1">
            <TextBlock Text="{Binding PromptPlaceholderText}" Visibility="{Binding PromptPlaceholderVisibility}" IsHitTestVisible="False"
                       Foreground="{DynamicResource ComposerTextMuted}" FontSize="14" FontWeight="Regular" Margin="44,0,320,0" VerticalAlignment="Center" />
            <TextBox x:Name="ChatPromptBox" Text="{Binding PromptText, UpdateSourceTrigger=PropertyChanged}" PreviewKeyDown="PromptBox_KeyDown" DataObject.Pasting="PromptBox_Pasting"
                     Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ComposerTextPrimary}" CaretBrush="{DynamicResource ComposerCaretBrush}" Padding="0"
                     FontSize="14" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Hidden" Margin="44,0,320,0" VerticalAlignment="Center" VerticalContentAlignment="Center"
                     AutomationProperties.Name="Message" AutomationProperties.HelpText="Press Enter to send. Press Shift+Enter for a new line." />
          </Grid>
          <Grid Grid.Row="1" VerticalAlignment="Center">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource ComposerIconButton}" Width="30" Height="30" Click="AddFile_Click" Margin="0,0,8,0" ToolTip="{Binding AddFileToolTip}" AutomationProperties.Name="{Binding AddFileToolTip}"><local:LucideIcon Icon="plus" Size="15" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" IsHitTestVisible="False" /></Button>

            <Grid Grid.Column="1" x:Name="ChatApprovalPickerHost" Margin="0,0,10,0" Visibility="Collapsed">
              <Button Style="{StaticResource ComposerPillButton}" Click="ChatApproval_Click">
                <StackPanel Orientation="Horizontal">
                  <local:LucideIcon Icon="shield-check" Size="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,6,0" />
                  <TextBlock Text="{Binding ApprovalLabel}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="13" FontWeight="Medium" />
                  <local:LucideIcon Icon="chevron-down" Size="13" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="7,1,0,0" />
                </StackPanel>
              </Button>
              <Popup PlacementTarget="{Binding ElementName=ChatApprovalPickerHost}" Placement="Top" VerticalOffset="-8" AllowsTransparency="True" StaysOpen="False" IsOpen="{Binding IsChatApprovalPickerOpen, Mode=TwoWay}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                <Border Width="392" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="14" Padding="10,9">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="6,0,6,6">
                      <TextBlock Text="{Binding ApprovalQuestionText}" Foreground="{DynamicResource TextMuted}" FontSize="13" FontWeight="Medium" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding ApprovalOptions}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Style="{StaticResource ApprovalMenuOptionButton}" Click="ApprovalOption_Click" IsEnabled="{Binding IsEnabled}">
                            <Grid>
                              <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /><ColumnDefinition Width="22" /></Grid.ColumnDefinitions>
                              <local:LucideIcon Icon="{Binding Icon}" Size="15" Stroke="#C8C9CE" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0" />
                              <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Medium" />
                                <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextDim}" FontSize="12" TextWrapping="Wrap" Margin="0,1,0,0" />
                              </StackPanel>
                              <TextBlock Grid.Column="2" Text="{Binding SelectedMark}" Foreground="{DynamicResource TextPrimary}" FontSize="17" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Grid>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </Popup>
            </Grid>

            <local:LucideIcon Grid.Column="3" Icon="clock" Visibility="Collapsed" Size="15" Stroke="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,14,0" />
            <Grid Grid.Column="4" x:Name="ChatThinkingPickerHost" Margin="0,0,8,0">
              <Button Style="{StaticResource ComposerPillButton}" Background="Transparent" Click="ChatThinking_Click">
                <StackPanel Orientation="Horizontal">
                  <local:LucideIcon Icon="zap" Size="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,6,0" />
                  <TextBlock Text="{Binding ModelControlLabel}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="14" FontWeight="Medium" />
                  <local:LucideIcon Icon="chevron-down" Size="12" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="6,1,0,0" />
                </StackPanel>
              </Button>
              <Popup PlacementTarget="{Binding ElementName=ChatThinkingPickerHost}" Placement="Top" VerticalOffset="-8" AllowsTransparency="True" StaysOpen="False" IsOpen="{Binding IsChatThinkingPickerOpen, Mode=TwoWay}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                <Border Width="344" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="14" Padding="12,10">
                  <StackPanel>
                    <TextBlock Text="{Binding ReasoningText}" Foreground="{DynamicResource TextMuted}" FontSize="14" FontWeight="Medium" Margin="8,0,8,8" />
                    <ItemsControl ItemsSource="{Binding ReasoningOptions}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Style="{StaticResource ApprovalMenuOptionButton}" Click="ReasoningOption_Click">
                            <Grid>
                              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="24" /></Grid.ColumnDefinitions>
                              <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Regular" />
                              <TextBlock Grid.Column="1" Text="{Binding SelectedMark}" Foreground="{DynamicResource TextPrimary}" FontSize="17" HorizontalAlignment="Center" />
                            </Grid>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Height="1" Background="{DynamicResource PopupDivider}" Margin="8,7" />
                    <TextBlock Text="{Binding ModelText}" Foreground="{DynamicResource TextMuted}" FontSize="13" FontWeight="Medium" Margin="8,0,8,6" />
                    <ItemsControl ItemsSource="{Binding ModelOptions}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Style="{StaticResource ApprovalMenuOptionButton}" Click="ModelOption_Click">
                            <Grid>
                              <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /><ColumnDefinition Width="24" /></Grid.ColumnDefinitions>
                              <local:LucideIcon Icon="zap" Size="14" Stroke="#C8C9CE" />
                              <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Medium" />
                                <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextDim}" FontSize="11" Margin="0,2,0,0" />
                              </StackPanel>
                              <TextBlock Grid.Column="2" Text="{Binding SelectedMark}" Foreground="{DynamicResource TextPrimary}" FontSize="17" HorizontalAlignment="Center" />
                            </Grid>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </Popup>
            </Grid>
            <Grid Grid.Column="5" x:Name="ChatVoicePickerHost" Margin="0,0,8,0">
              <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ComposerIconButton}" Width="30" Height="30" Click="Voice_Click" ToolTip="{Binding VoiceBackendLabel}" AutomationProperties.Name="{Binding VoiceBackendLabel}"><local:LucideIcon Icon="{Binding VoiceButtonLabel}" Size="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
                <Button Width="16" Height="30" Style="{StaticResource ComposerIconButton}" Click="VoicePicker_Click" ToolTip="{Binding VoiceModeToolTip}" AutomationProperties.Name="{Binding VoiceModeToolTip}"><local:LucideIcon Icon="chevron-down" Size="11" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
              </StackPanel>
              <Popup PlacementTarget="{Binding ElementName=ChatVoicePickerHost}" Placement="Top" VerticalOffset="-8" AllowsTransparency="True" StaysOpen="False" IsOpen="{Binding IsChatVoicePickerOpen, Mode=TwoWay}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                <Border Width="380" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="14" Padding="12">
                  <StackPanel>
                    <TextBlock Text="{Binding VoiceModeTitle}" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold" Margin="8,4,8,8" />
                    <ItemsControl ItemsSource="{Binding VoiceOptions}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Style="{StaticResource GhostButton}" Click="VoiceOption_Click" Margin="0,0,0,3">
                            <Grid Margin="8,8">
                              <Grid.ColumnDefinitions><ColumnDefinition Width="58" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                              <TextBlock Text="{Binding Badge}" Foreground="{DynamicResource TextDim}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Top" />
                              <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextDim}" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0" />
                              </StackPanel>
                            </Grid>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </Popup>
            </Grid>
            <Button Grid.Column="6" Style="{StaticResource CodexSendButton}" Width="32" Height="32" Click="Send_Click" ToolTip="{Binding SendButtonToolTip}" AutomationProperties.Name="{Binding SendButtonToolTip}"><local:LucideIcon Icon="{Binding SendButtonGlyph}" Size="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" IsHitTestVisible="False" /></Button>
          </Grid>
        </Grid>
      </Border>
      </StackPanel>
    </Grid>

    <Border Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="62,14,62,0"
            Background="{DynamicResource ComposerBg}" BorderBrush="{DynamicResource ComposerBorder}" BorderThickness="1" CornerRadius="12" Padding="14,10"
            Visibility="{Binding IsPinnedSummaryVisible, Converter={StaticResource BoolToVisibility}}">
      <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
        <TextBlock Text="Pinned" Foreground="{DynamicResource TextDim}" FontSize="11" FontWeight="SemiBold" Margin="0,0,12,0" />
        <TextBlock Grid.Column="1" Text="{Binding PinnedSummaryText}" Foreground="{DynamicResource TextMuted}" FontSize="12" TextTrimming="CharacterEllipsis" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="62,0,62,22"
            Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="14" Padding="16,12"
            Visibility="{Binding IsBottomPanelVisible, Converter={StaticResource BoolToVisibility}}">
      <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
        <TextBlock Text="Bottom Panel" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold" />
        <TextBlock Grid.Column="1" Text="{Binding SessionStatsText}" Foreground="{DynamicResource TextDim}" FontSize="12" />
        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding StatusText}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,8,0,0" TextTrimming="CharacterEllipsis" />
      </Grid>
    </Border>

    <Border x:Name="BottomStatusChrome" Grid.Row="2" Grid.ColumnSpan="3" Background="{DynamicResource GlassTitleBg}" BorderBrush="#2830343D" BorderThickness="0,1,0,0" Padding="14,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
      <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Grid x:Name="BottomWorkspacePickerHost" Height="24">
            <Button Style="{StaticResource GhostButton}" Height="24" Padding="8,0" Click="BottomProjectPath_Click" ToolTip="{Binding CurrentProjectToolTip}">
              <StackPanel Orientation="Horizontal">
                <local:LucideIcon Icon="monitor" Size="13" Stroke="{DynamicResource TextDim}" Margin="0,0,6,0" />
                <TextBlock Text="{Binding WorkspaceChipLabel}" Foreground="{DynamicResource TextMuted}" FontSize="12" />
              </StackPanel>
            </Button>
            <Popup PlacementTarget="{Binding ElementName=BottomWorkspacePickerHost}"
                   Placement="Top"
                   HorizontalOffset="0"
                   VerticalOffset="-8"
                   AllowsTransparency="True"
                   StaysOpen="False"
                   IsOpen="{Binding IsBottomProjectPickerOpen, Mode=TwoWay}"
                   DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
              <Border Width="360" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="14" Padding="14">
                <StackPanel>
                  <Border Background="{DynamicResource ComposerChipBg}" BorderBrush="{DynamicResource ComposerChipBorder}" BorderThickness="1" CornerRadius="9" Padding="10,7" Margin="0,0,0,10">
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="24" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <local:LucideIcon Icon="search" Size="15" Stroke="{DynamicResource TextDim}" VerticalAlignment="Center" />
                      <TextBox Grid.Column="1" Text="{Binding ProjectSearchText, UpdateSourceTrigger=PropertyChanged}"
                               Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}"
                               FontSize="14" />
                    </Grid>
                  </Border>

                  <ItemsControl ItemsSource="{Binding ProjectPickerItems}" Margin="0,0,0,8">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Style="{StaticResource GhostButton}" Click="ProjectChoice_Click" Margin="0,0,0,2">
                          <Grid Margin="8,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="26" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <local:LucideIcon Icon="folder" Size="14" Stroke="{DynamicResource TextMuted}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1">
                              <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                              <TextBlock Text="{Binding Path}" Foreground="{DynamicResource TextDim}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="✓" Foreground="{DynamicResource TextMuted}" FontSize="14" VerticalAlignment="Center" Margin="10,0,0,0" />
                          </Grid>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <Border BorderBrush="{DynamicResource PopupDivider}" BorderThickness="0,1,0,0" Margin="6,2,6,8" />

                  <Grid x:Name="BottomNewProjectMenuHost" Margin="0,0,0,2">
                    <Button Style="{StaticResource GhostButton}" Click="ProjectNewMenu_Click">
                      <Grid Margin="8,9"><Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <local:LucideIcon Icon="plus" Size="16" Stroke="{DynamicResource TextPrimary}" />
                        <TextBlock Grid.Column="1" Text="{Binding NewProjectText}" Foreground="{DynamicResource TextPrimary}" FontSize="14" />
                        <local:LucideIcon Grid.Column="2" Icon="chevron-right" Size="13" Stroke="{DynamicResource TextDim}" />
                      </Grid>
                    </Button>
                    <Popup PlacementTarget="{Binding ElementName=BottomNewProjectMenuHost}"
                           Placement="Right"
                           HorizontalOffset="8"
                           VerticalOffset="0"
                           AllowsTransparency="True"
                           StaysOpen="False"
                           IsOpen="{Binding IsNewProjectMenuOpen, Mode=TwoWay}"
                           DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                      <Border Width="260" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="12" Padding="10">
                        <StackPanel>
                          <Button Style="{StaticResource GhostButton}" Click="ProjectCreateNamed_Click" Margin="0,0,0,2">
                            <Grid Margin="8,9"><Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                              <local:LucideIcon Icon="plus" Size="16" Stroke="{DynamicResource TextPrimary}" />
                              <TextBlock Grid.Column="1" Text="{Binding NewBlankProjectText}" Foreground="{DynamicResource TextPrimary}" FontSize="14" />
                            </Grid>
                          </Button>
                          <Button Style="{StaticResource GhostButton}" Click="ProjectUseFolder_Click">
                            <Grid Margin="8,9"><Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                              <local:LucideIcon Icon="folder" Size="15" Stroke="{DynamicResource TextMuted}" />
                              <TextBlock Grid.Column="1" Text="{Binding UseExistingFolderText}" Foreground="{DynamicResource TextPrimary}" FontSize="14" />
                            </Grid>
                          </Button>
                        </StackPanel>
                      </Border>
                    </Popup>
                  </Grid>
                  <Button Style="{StaticResource GhostButton}" Click="ProjectNoProject_Click">
                    <Grid Margin="8,9"><Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <local:LucideIcon Icon="x" Size="15" Stroke="{DynamicResource TextMuted}" />
                      <TextBlock Grid.Column="1" Text="{Binding DefaultChatNoProjectText}" Foreground="{DynamicResource TextPrimary}" FontSize="14" />
                    </Grid>
                  </Button>
                </StackPanel>
              </Border>
            </Popup>
          </Grid>
          <Border Width="1" Height="14" Background="{DynamicResource Line}" Margin="6,0,10,0" />
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <local:LucideIcon Icon="zap" Size="13" Stroke="{DynamicResource TextDim}" Margin="0,0,6,0" />
            <TextBlock Text="{Binding LocalReadyText}" Foreground="{DynamicResource TextDim}" FontSize="12" />
          </StackPanel>
          <Border Width="1" Height="14" Background="{DynamicResource Line}" Margin="10,0" />
          <TextBlock x:Name="BottomLiveStatusText" Text="{Binding StatusText}" Foreground="{DynamicResource TextMuted}" FontSize="12"
                     MaxWidth="420" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                     AutomationProperties.Name="Status" AutomationProperties.LiveSetting="Polite" />
          <Grid x:Name="BottomApprovalPickerHost" Margin="10,0,0,0">
            <Button Style="{StaticResource GhostButton}" Height="24" Padding="4,0" Click="BottomApproval_Click" ToolTip="{Binding ApprovalModeToolTip}">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <local:LucideIcon Icon="shield-check" Size="13" Stroke="{DynamicResource TextDim}" Margin="0,0,6,0" />
                <TextBlock Text="{Binding ApprovalLabel}" Foreground="{DynamicResource TextDim}" FontSize="12" />
              </StackPanel>
            </Button>
            <Popup PlacementTarget="{Binding ElementName=BottomApprovalPickerHost}" Placement="Top" VerticalOffset="-8" AllowsTransparency="True" StaysOpen="False" IsOpen="{Binding IsBottomApprovalPickerOpen, Mode=TwoWay}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
              <Border Width="392" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="14" Padding="10,9">
                <StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="6,0,6,6">
                    <TextBlock Text="{Binding ApprovalQuestionText}" Foreground="{DynamicResource TextMuted}" FontSize="13" FontWeight="Medium" />
                  </StackPanel>
                  <ItemsControl ItemsSource="{Binding ApprovalOptions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Style="{StaticResource ApprovalMenuOptionButton}" Click="ApprovalOption_Click" IsEnabled="{Binding IsEnabled}">
                          <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /><ColumnDefinition Width="22" /></Grid.ColumnDefinitions>
                            <local:LucideIcon Icon="{Binding Icon}" Size="15" Stroke="#C8C9CE" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0" />
                            <StackPanel Grid.Column="1">
                              <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Medium" />
                              <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextDim}" FontSize="12" TextWrapping="Wrap" Margin="0,1,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding SelectedMark}" Foreground="{DynamicResource TextPrimary}" FontSize="17" VerticalAlignment="Center" HorizontalAlignment="Center" />
                          </Grid>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </Popup>
          </Grid>
        </StackPanel>
        <Grid Grid.Column="1" x:Name="BottomUsageInfoHost" VerticalAlignment="Center">
          <Button Style="{StaticResource GhostButton}" Height="24" Padding="6,0" Click="BottomUsage_Click" ToolTip="Session info">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="in" Foreground="{DynamicResource TextDim}" FontSize="11" Margin="0,0,4,0" />
              <TextBlock Text="{Binding TopInputText}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,10,0" />
              <TextBlock Text="out" Foreground="{DynamicResource TextDim}" FontSize="11" Margin="0,0,4,0" />
              <TextBlock Text="{Binding TopOutputText}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,10,0" />
              <TextBlock Text="cache" Foreground="{DynamicResource TextDim}" FontSize="11" Margin="0,0,4,0" />
              <TextBlock Text="{Binding TopCacheText}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,10,0" />
              <TextBlock Text="{Binding TopCostText}" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold" Margin="0,0,10,0" />
              <Grid Width="30" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                <Border Background="{DynamicResource PopupDivider}" CornerRadius="3" Opacity="0.72" />
                <Border Width="{Binding TopContextFillWidth}" Background="{DynamicResource Line}" CornerRadius="3" HorizontalAlignment="Left" Opacity="0.95" />
              </Grid>
              <TextBlock Text="ctx" Foreground="{DynamicResource TextDim}" FontSize="11" Margin="0,0,4,0" />
              <TextBlock Text="{Binding TopContextText}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,0" />
            </StackPanel>
          </Button>
          <Popup x:Name="SessionInfoPopup" PlacementTarget="{Binding ElementName=BottomUsageInfoHost}" Placement="Top" VerticalOffset="-10" AllowsTransparency="True" StaysOpen="False" IsOpen="{Binding IsSessionInfoPopupOpen, Mode=TwoWay}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <Border x:Name="SessionInfoPopupBorder" Width="720" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="14" Padding="18,15">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="1*" /><ColumnDefinition Width="1.2*" /></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,26,0">
                  <TextBlock Text="Session Info" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="Medium" Margin="0,0,0,12" />
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="File" Foreground="{DynamicResource TextDim}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" />
                    <TextBlock Grid.Column="1" Text="{Binding SessionInfoFile}" Foreground="{DynamicResource TextMuted}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" TextWrapping="Wrap" />
                  </Grid>
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="ID" Foreground="{DynamicResource TextDim}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" />
                    <TextBlock Grid.Column="1" Text="{Binding SessionInfoId}" Foreground="{DynamicResource TextMuted}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" TextWrapping="Wrap" />
                  </Grid>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,26,0">
                  <TextBlock Text="Messages" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="Medium" Margin="0,0,0,12" />
                  <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="User" Foreground="{DynamicResource TextDim}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" /><TextBlock Grid.Column="1" Text="{Binding SessionInfoUserMessages}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Right" FontFamily="{DynamicResource IpiCodeFontFamily}" /></Grid>
                  <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Assistant" Foreground="{DynamicResource TextDim}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" /><TextBlock Grid.Column="1" Text="{Binding SessionInfoAssistantMessages}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Right" FontFamily="{DynamicResource IpiCodeFontFamily}" /></Grid>
                  <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Tool Calls" Foreground="{DynamicResource TextDim}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" /><TextBlock Grid.Column="1" Text="{Binding SessionInfoToolCalls}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Right" FontFamily="{DynamicResource IpiCodeFontFamily}" /></Grid>
                  <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Tool Results" Foreground="{DynamicResource TextDim}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" /><TextBlock Grid.Column="1" Text="{Binding SessionInfoToolResults}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Right" FontFamily="{DynamicResource IpiCodeFontFamily}" /></Grid>
                  <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Total" Foreground="{DynamicResource TextDim}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" /><TextBlock Grid.Column="1" Text="{Binding SessionInfoTotalMessages}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Right" FontFamily="{DynamicResource IpiCodeFontFamily}" /></Grid>
                </StackPanel>
                <StackPanel Grid.Column="2">
                  <TextBlock Text="Tokens" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="Medium" Margin="0,0,0,12" />
                  <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="86" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Input" Foreground="{DynamicResource TextDim}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" /><TextBlock Grid.Column="1" Text="{Binding SessionInfoInputTokens}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Right" FontFamily="{DynamicResource IpiCodeFontFamily}" /></Grid>
                  <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="86" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Output" Foreground="{DynamicResource TextDim}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" /><TextBlock Grid.Column="1" Text="{Binding SessionInfoOutputTokens}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Right" FontFamily="{DynamicResource IpiCodeFontFamily}" /></Grid>
                  <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="86" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Cache Read" Foreground="{DynamicResource TextDim}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" /><TextBlock Grid.Column="1" Text="{Binding SessionInfoCacheReadTokens}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Right" FontFamily="{DynamicResource IpiCodeFontFamily}" /></Grid>
                  <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="86" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Total" Foreground="{DynamicResource TextDim}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" /><TextBlock Grid.Column="1" Text="{Binding SessionInfoTotalTokens}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Right" FontFamily="{DynamicResource IpiCodeFontFamily}" /></Grid>
                  <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="86" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Cost" Foreground="{DynamicResource TextDim}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" /><TextBlock Grid.Column="1" Text="{Binding SessionInfoCost}" Foreground="{DynamicResource TextPrimary}" FontSize="12" HorizontalAlignment="Right" FontFamily="{DynamicResource IpiCodeFontFamily}" /></Grid>
                  <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="86" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Context" Foreground="{DynamicResource TextDim}" FontSize="12" FontFamily="{DynamicResource IpiCodeFontFamily}" /><TextBlock Grid.Column="1" Text="{Binding SessionInfoContext}" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Right" FontFamily="{DynamicResource IpiCodeFontFamily}" /></Grid>
                </StackPanel>
              </Grid>
            </Border>
          </Popup>
        </Grid>
      </Grid>
    </Border>

    <Border x:Name="RightPanel" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Width="{Binding RightPanelPanelWidth}" HorizontalAlignment="Right"
            Background="{DynamicResource Surface}" BorderBrush="Transparent" BorderThickness="0" Padding="18,18"
            Visibility="{Binding RightPanelPanelVisibility}" IsHitTestVisible="{Binding RightPanelPanelIsHitTestVisible}"
            MouseEnter="RightPanel_MouseEnter" MouseLeave="RightPanel_MouseLeave" Panel.ZIndex="82">
      <Border.RenderTransform>
        <TranslateTransform x:Name="RightPanelTranslate" />
      </Border.RenderTransform>
      <Grid>
        <DockPanel LastChildFill="True" Visibility="{Binding RightPanelActionsVisibility}">
          <Grid DockPanel.Dock="Top" Margin="0,0,0,18">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <TextBlock Text="{Binding RightPanelText}" Foreground="{DynamicResource TextDim}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Width="28" Height="28" Padding="0" Click="CloseRightPanel_Click" ToolTip="Close" AutomationProperties.Name="Close side panel">
              <local:LucideIcon Icon="x" Size="14" Stroke="{DynamicResource TextDim}" HorizontalAlignment="Center" />
            </Button>
          </Grid>
          <Grid>
            <ItemsControl ItemsSource="{Binding RightPanelActions}" VerticalAlignment="Center" Margin="20,0,20,0">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Style="{StaticResource GhostButton}" Click="RightPanelAction_Click" Margin="0,0,0,8" Padding="0">
                    <Border Background="{DynamicResource RowBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="12" Padding="14,12">
                      <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <local:LucideIcon Icon="{Binding Icon}" Size="16" Stroke="{DynamicResource TextMuted}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding Label}" Foreground="{DynamicResource TextPrimary}" FontSize="15" FontWeight="Medium" VerticalAlignment="Center" />
                        <Border Grid.Column="2" Background="{DynamicResource ComposerChipBg}" CornerRadius="10" Padding="9,3" Visibility="{Binding ShortcutVisibility}">
                          <TextBlock Text="{Binding Shortcut}" Foreground="{DynamicResource TextMuted}" FontSize="12" />
                        </Border>
                      </Grid>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>
        </DockPanel>

        <DockPanel LastChildFill="True" Visibility="{Binding RightPanelTerminalVisibility}">
          <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{Binding SideTerminalTitle}" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="{Binding SideTerminalCwd}" Foreground="{DynamicResource TextDim}" FontSize="11" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Width="28" Height="28" Padding="0" Click="CloseRightPanel_Click" AutomationProperties.Name="Close terminal"><local:LucideIcon Icon="x" Size="14" Stroke="{DynamicResource TextDim}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
          </Grid>
          <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Border Background="{DynamicResource RowBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="9" Padding="10,0" Height="34">
              <TextBox Text="{Binding SideTerminalCommand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}" FontFamily="{DynamicResource IpiCodeFontFamily}" FontSize="12" VerticalContentAlignment="Center" AutomationProperties.Name="Terminal command" />
            </Border>
            <Button Grid.Column="1" Style="{StaticResource ToolbarButton}" Click="SideTerminalRun_Click" Margin="8,0,0,0"><TextBlock Text="{Binding SideTerminalRunText}" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold" /></Button>
          </Grid>
          <TextBox Text="{Binding SideTerminalOutput, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="Transparent" BorderBrush="{DynamicResource Line}" BorderThickness="1" Foreground="{DynamicResource TextMuted}" FontFamily="{DynamicResource IpiCodeFontFamily}" FontSize="12" Padding="12" />
        </DockPanel>

        <DockPanel LastChildFill="True" Visibility="{Binding RightPanelBrowserVisibility}">
          <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="28" /></Grid.ColumnDefinitions>
            <Border Background="{DynamicResource RowBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="9" Padding="10,0" Height="34" Margin="0,0,8,0">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="28" /></Grid.ColumnDefinitions>
                <TextBox x:Name="SideBrowserAddressBox" Text="{Binding SideBrowserUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" KeyDown="SideBrowserAddress_KeyDown" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}" FontFamily="{DynamicResource IpiCodeFontFamily}" FontSize="12" VerticalContentAlignment="Center" AutomationProperties.Name="Browser address" />
                <Button Grid.Column="1" Style="{StaticResource GhostButton}" Width="24" Height="24" Padding="0" Click="SideBrowserOpen_Click" ToolTip="{Binding SideBrowserOpenText}"><local:LucideIcon Icon="external-link" Size="13" Stroke="{DynamicResource TextDim}" HorizontalAlignment="Center" /></Button>
              </Grid>
            </Border>
            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Width="28" Height="28" Padding="0" Click="CloseRightPanel_Click" AutomationProperties.Name="Close browser"><local:LucideIcon Icon="x" Size="14" Stroke="{DynamicResource TextDim}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
          </Grid>
          <Border BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="9" ClipToBounds="True" Background="{DynamicResource RowBg}">
            <wv2:WebView2 x:Name="SideBrowserWebView" Source="{Binding SideBrowserUri}" NavigationStarting="SideBrowserWebView_NavigationStarting" NavigationCompleted="SideBrowserWebView_NavigationCompleted" />
          </Border>
        </DockPanel>

        <DockPanel LastChildFill="True" Visibility="{Binding RightPanelFilesVisibility}">
          <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <TextBlock Text="{Binding SideFilesTitle}" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Width="28" Height="28" Padding="0" Click="CloseRightPanel_Click" AutomationProperties.Name="Close files"><local:LucideIcon Icon="x" Size="14" Stroke="{DynamicResource TextDim}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
          </Grid>
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding RightPanelFileItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Style="{StaticResource GhostButton}" Click="RightPanelFile_Click" Padding="0" Margin="0,0,0,4">
                    <Grid Height="30">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="24" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <local:LucideIcon Icon="file" Size="13" Stroke="{DynamicResource TextDim}" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding RelativePath}" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>

        <DockPanel LastChildFill="True" Visibility="{Binding RightPanelChatVisibility}">
          <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <TextBlock Text="{Binding SideChatTitle}" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Width="28" Height="28" Padding="0" Click="SideChatNew_Click" ToolTip="{Binding NewTemporarySideChatText}"><local:LucideIcon Icon="plus" Size="14" Stroke="{DynamicResource TextDim}" HorizontalAlignment="Center" /></Button>
            <Button Grid.Column="2" Style="{StaticResource GhostButton}" Width="28" Height="28" Padding="0" Click="CloseRightPanel_Click" AutomationProperties.Name="Close side chat"><local:LucideIcon Icon="x" Size="14" Stroke="{DynamicResource TextDim}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
          </Grid>
          <Border DockPanel.Dock="Bottom" Background="{DynamicResource ComposerBg}" BorderBrush="{DynamicResource ComposerBorder}" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,12,0,0">
            <StackPanel>
              <Border Background="{DynamicResource ComposerChipBg}" BorderBrush="{DynamicResource ComposerChipBorder}" BorderThickness="1" CornerRadius="12" Padding="9,6" HorizontalAlignment="Left" Visibility="{Binding SideChatContextVisibility}" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                  <local:LucideIcon Icon="message-square" Size="13" Stroke="{DynamicResource TextDim}" Margin="0,0,6,0" />
                  <TextBlock Text="{Binding SideChatContextLabel}" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <TextBox Text="{Binding SideChatInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewKeyDown="SideChatInput_KeyDown" MinHeight="42" MaxHeight="110" AcceptsReturn="True" TextWrapping="Wrap" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource CaretBrush}" SelectionBrush="{DynamicResource SelectionBrush}" FontSize="13" Padding="0" AutomationProperties.Name="Side chat message" AutomationProperties.HelpText="Press Enter to send. Press Shift+Enter for a new line." />
              <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="{Binding SideChatTemporaryNote}" Foreground="{DynamicResource TextDim}" FontSize="11" VerticalAlignment="Center" />
                <Button Grid.Column="1" Style="{StaticResource ToolbarButton}" Click="SideChatSend_Click">
                  <TextBlock Text="{Binding SideChatSendText}" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold" />
                </Button>
              </Grid>
            </StackPanel>
          </Border>
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding RightPanelChatRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
                    <StackPanel>
                      <TextBlock Text="{Binding Badge}" Foreground="{DynamicResource TextDim}" FontSize="10" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding DisplayTitle}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap" LineHeight="17" Margin="0,4,0,0" />
                      <TextBlock Text="{Binding DisplayDetail}" Foreground="{DynamicResource TextDim}" FontSize="11" TextWrapping="Wrap" LineHeight="16" Margin="0,4,0,0" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>

        <DockPanel LastChildFill="True" Visibility="{Binding InspectorRowsVisibility}">
          <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
            <TextBlock Text="Inspector" Foreground="{DynamicResource TextDim}" FontSize="12" FontWeight="SemiBold" />
            <TextBlock Text="{Binding InspectorTitle}" FontSize="19" FontWeight="SemiBold" Margin="0,6,0,0" />
          </StackPanel>
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding InspectorRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="92" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding Badge}" Foreground="{DynamicResource TextDim}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>

        <DockPanel LastChildFill="True" Visibility="{Binding FilePanelVisibility}">
          <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{Binding FilePanelTitle}" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
              <TextBlock Text="{Binding FilePanelPath}" Foreground="{DynamicResource TextDim}" FontSize="12" Margin="0,7,0,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Width="28" Height="28" Padding="0" Click="CloseRightPanel_Click" ToolTip="Close" AutomationProperties.Name="Close file preview">
              <local:LucideIcon Icon="x" Size="14" Stroke="{DynamicResource TextDim}" HorizontalAlignment="Center" />
            </Button>
            <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding FilePanelMeta}" Foreground="{DynamicResource TextDim}" FontSize="12" />
                <TextBlock Text=" · " Foreground="{DynamicResource TextDim}" FontSize="12" />
                <TextBlock Text="{Binding FilePanelStatus}" Foreground="{DynamicResource FeedbackAccent}" FontSize="12" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource ToolbarButton}" Click="FilePreviewMode_Click"><TextBlock Text="Preview" Foreground="{DynamicResource TextMuted}" FontSize="12" FontWeight="{Binding FilePreviewButtonWeight}" /></Button>
                <Button Style="{StaticResource ToolbarButton}" Click="FileRawMode_Click"><TextBlock Text="Raw" Foreground="{DynamicResource TextMuted}" FontSize="12" FontWeight="{Binding FileRawButtonWeight}" /></Button>
                <Button Style="{StaticResource ToolbarButton}" Click="FileSave_Click" IsEnabled="{Binding CanEditFilePanel}"><TextBlock Text="Save" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold" /></Button>
              </StackPanel>
            </Grid>
          </Grid>

          <Grid>
            <Border Visibility="{Binding FilePreviewVisibility}" Background="Transparent" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="12">
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <ScrollViewer.Resources>
                  <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource IpiThinScrollBar}" />
                </ScrollViewer.Resources>
                <TextBlock Text="{Binding FilePanelText}" Foreground="{DynamicResource TextPrimary}" FontFamily="{DynamicResource IpiCodeFontFamily}" FontSize="12.5" TextWrapping="Wrap" LineHeight="19" />
              </ScrollViewer>
            </Border>
            <TextBox Visibility="{Binding FileRawEditorVisibility}" Text="{Binding FilePanelText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="Transparent" BorderBrush="{DynamicResource Line}" BorderThickness="1" Foreground="{DynamicResource TextPrimary}" FontFamily="{DynamicResource IpiCodeFontFamily}" FontSize="12.5" Padding="12" AutomationProperties.Name="File editor">
              <TextBox.Resources>
                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource IpiThinScrollBar}" />
              </TextBox.Resources>
              <TextBox.Style>
                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding CanEditFilePanel}" Value="False"><Setter Property="IsReadOnly" Value="True" /></DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBox.Style>
            </TextBox>
          </Grid>
        </DockPanel>
      </Grid>
    </Border>

    <Thumb x:Name="RightPanelResizeThumb" Grid.Row="1"
           Grid.Column="0"
           Grid.ColumnSpan="3"
           Width="14"
           Margin="{Binding RightPanelResizeThumbMargin}"
           HorizontalAlignment="Right"
           VerticalAlignment="Stretch"
           Cursor="SizeWE"
           Visibility="{Binding RightPanelResizeThumbVisibility}"
           Panel.ZIndex="120"
           MouseEnter="RightPanelResizeThumb_MouseEnter"
           MouseMove="RightPanelResizeThumb_MouseMove"
           MouseLeave="RightPanelResizeThumb_MouseLeave"
           DragStarted="RightPanelResizeThumb_DragStarted"
           DragDelta="RightPanelResizeThumb_DragDelta"
           DragCompleted="RightPanelResizeThumb_DragCompleted">
      <Thumb.Template>
        <ControlTemplate TargetType="{x:Type Thumb}">
          <Border Background="#01000000" />
        </ControlTemplate>
      </Thumb.Template>
    </Thumb>

    <Border x:Name="RightPanelResizeCursor" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
            Width="9" Height="34" CornerRadius="4.5" HorizontalAlignment="Left" VerticalAlignment="Top"
            Margin="0"
            Background="#DFFFFFFF"
            BorderBrush="#66000000" BorderThickness="1"
            Visibility="Collapsed"
            IsHitTestVisible="False" Opacity="0" Panel.ZIndex="130">
      <Grid>
        <Border Width="1" Height="20" Background="#AA000000" HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Border Grid.Row="0"
            Grid.RowSpan="3"
            Grid.ColumnSpan="3"
            Width="14"
            HorizontalAlignment="Right"
            Background="#01000000"
            Visibility="{Binding RightPanelAutoHideEdgeVisibility}"
            MouseEnter="RightPanelEdge_MouseEnter"
            MouseMove="RightPanelEdge_MouseEnter"
            Panel.ZIndex="100" />
  </Grid>
  </Border>
</Window>
