          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Style="{StaticResource GhostButton}" Click="PanelRow_Click" Margin="0,0,0,8">
                <Border Background="{DynamicResource RowBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="13,11">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="92" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Badge}" Foreground="{DynamicResource TextDim}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,5,0,0" />
                    </StackPanel>
                  </Grid>
                </Border>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>

    <Grid Grid.Row="1" Grid.Column="1" Margin="42,38,62,28" Visibility="{Binding ChatPanelVisibility}">
