                    <Border Background="{DynamicResource RowBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="8" Padding="12,9">
                      <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Medium" />
                          <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextDim}" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </Expander.Header>
                  <Border Background="Transparent" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="7" Padding="0" Margin="18,7,0,0">
                    <TextBox Text="{Binding Text, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled" Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource TextMuted}" CaretBrush="{DynamicResource CaretBrush}" SelectionBrush="{DynamicResource SelectionBrush}"
                             FontFamily="{DynamicResource IpiCodeFontFamily}" FontSize="13" Padding="11,9" />
                  </Border>
                </Expander>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,0" MaxWidth="1060" HorizontalAlignment="Stretch" Visibility="{Binding MainRowsVisibility}">
