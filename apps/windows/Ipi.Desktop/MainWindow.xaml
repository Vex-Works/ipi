<Window x:Class="Ipi.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Ipi.Desktop"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ipi" Width="1460" Height="900" MinWidth="960" MinHeight="620"
        WindowStartupLocation="CenterScreen" Background="Transparent"
        WindowStyle="None" ResizeMode="CanResize"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="MainWindow_Closing">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="42" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    <FontFamily x:Key="IpiTextFontFamily">Segoe UI Variable Text, Segoe UI, Microsoft YaHei UI, Microsoft YaHei, DengXian</FontFamily>
    <FontFamily x:Key="IpiCodeFontFamily">Cascadia Mono, Consolas, Segoe UI Mono, Microsoft YaHei UI</FontFamily>
    <FontFamily x:Key="IpiIconFontFamily">Segoe UI Symbol</FontFamily>

    <SolidColorBrush x:Key="AppBg" Color="#111214" />
    <SolidColorBrush x:Key="GlassShellBg" Color="#DD111214" />
    <SolidColorBrush x:Key="GlassTitleBg" Color="#E6171A20" />
    <SolidColorBrush x:Key="SidebarBg" Color="#E81D2027" />
    <SolidColorBrush x:Key="SidebarHover" Color="#2C2F37" />
    <SolidColorBrush x:Key="ControlHoverBg" Color="#3A3A3B" />
    <SolidColorBrush x:Key="MenuHoverBg" Color="#373738" />
    <SolidColorBrush x:Key="SendButtonHoverBg" Color="#F5F6F8" />
    <SolidColorBrush x:Key="Surface" Color="#181A1F" />
    <SolidColorBrush x:Key="ComposerBg" Color="#2B2C2E" />
    <SolidColorBrush x:Key="ComposerBorder" Color="#3F444D" />
    <SolidColorBrush x:Key="ComposerTextPrimary" Color="#F3F4F6" />
    <SolidColorBrush x:Key="ComposerTextMuted" Color="#A9ADB7" />
    <SolidColorBrush x:Key="ComposerCaretBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="ComposerHoverBg" Color="#3A3A3B" />
    <SolidColorBrush x:Key="ComposerHoverText" Color="#F3F4F6" />
    <SolidColorBrush x:Key="ComposerChipBg" Color="#3A3A3B" />
    <SolidColorBrush x:Key="ComposerChipBorder" Color="#4C4C4F" />
    <SolidColorBrush x:Key="UserBubbleBg" Color="#16FFFFFF" />
    <SolidColorBrush x:Key="UserBubbleBorder" Color="#00FFFFFF" />
    <SolidColorBrush x:Key="PopupBg" Color="#2B2B2C" />
    <SolidColorBrush x:Key="PopupText" Color="#F4F6FA" />
    <SolidColorBrush x:Key="PopupBorder" Color="#48484A" />
    <SolidColorBrush x:Key="PopupDivider" Color="#3D3D40" />
    <SolidColorBrush x:Key="SendButtonIdleBg" Color="#E7E9ED" />
    <SolidColorBrush x:Key="SendButtonIdleIcon" Color="#111214" />
    <SolidColorBrush x:Key="SendButtonRunningBg" Color="#2B2D31" />
    <SolidColorBrush x:Key="SendButtonRunningIcon" Color="#E7E9ED" />
    <SolidColorBrush x:Key="RowBg" Color="#16181D" />
    <SolidColorBrush x:Key="FeedbackRowBg" Color="#142019" />
    <SolidColorBrush x:Key="FeedbackRowBorder" Color="#315E44" />
    <SolidColorBrush x:Key="FeedbackAccent" Color="#54C77A" />
    <SolidColorBrush x:Key="FeedbackSoftBg" Color="#202226" />
    <SolidColorBrush x:Key="Line" Color="#30343D" />
    <SolidColorBrush x:Key="ChatRailLine" Color="#30343D" />
    <SolidColorBrush x:Key="ChatScrollThumb" Color="#747B86" />
    <SolidColorBrush x:Key="TextPrimary" Color="#F3F4F6" />
    <SolidColorBrush x:Key="TextMuted" Color="#A9ADB7" />
    <SolidColorBrush x:Key="TextDim" Color="#8A919E" />
    <SolidColorBrush x:Key="CaretBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#4B6FEA" />

    <Style TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{DynamicResource IpiTextFontFamily}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="FontFamily" Value="{DynamicResource IpiTextFontFamily}" />
      <Setter Property="CaretBrush" Value="{DynamicResource CaretBrush}" />
      <Setter Property="SelectionBrush" Value="{DynamicResource SelectionBrush}" />
    </Style>

    <Style x:Key="IpiKeyboardFocusStyle" TargetType="Control">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate>
            <Border BorderBrush="{DynamicResource FeedbackAccent}" BorderThickness="2" CornerRadius="8" Margin="-3" SnapsToDevicePixels="True" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <HierarchicalDataTemplate DataType="{x:Type local:FileExplorerNode}" ItemsSource="{Binding Children}">
      <Grid Height="24" Margin="0,0,0,1">
        <Grid.ColumnDefinitions><ColumnDefinition Width="18" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
        <local:LucideIcon Icon="{Binding Icon}" Size="13" Stroke="{DynamicResource TextDim}" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource TextMuted}" FontSize="12.5" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
      </Grid>
    </HierarchicalDataTemplate>

    <Style x:Key="ExplorerTreeItemStyle" TargetType="{x:Type TreeViewItem}">
      <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
      <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
    </Style>

    <Style x:Key="IpiThinScrollBar" TargetType="{x:Type ScrollBar}">
      <Setter Property="Width" Value="8" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type ScrollBar}">
            <Grid Background="Transparent" Width="{TemplateBinding Width}">
              <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="False" /></Track.DecreaseRepeatButton>
                <Track.Thumb>
                  <Thumb MinHeight="42" Background="{DynamicResource TextDim}" Focusable="False">
                    <Thumb.Template>
                      <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="4" HorizontalAlignment="Center" Background="{TemplateBinding Background}" CornerRadius="2" Opacity="0.42" />
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
                <Track.IncreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="False" /></Track.IncreaseRepeatButton>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="Orientation" Value="Horizontal">
          <Setter Property="Width" Value="Auto" />
          <Setter Property="Height" Value="8" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="{x:Type ScrollBar}">
                <Grid Background="Transparent" Height="{TemplateBinding Height}">
                  <Track x:Name="PART_Track" Orientation="Horizontal">
                    <Track.DecreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}" Opacity="0" Focusable="False" /></Track.DecreaseRepeatButton>
                    <Track.Thumb>
                      <Thumb MinWidth="42" Background="{DynamicResource TextDim}" Focusable="False">
                        <Thumb.Template>
                          <ControlTemplate TargetType="{x:Type Thumb}">
                            <Border Height="4" VerticalAlignment="Center" Background="{TemplateBinding Background}" CornerRadius="2" Opacity="0.42" />
                          </ControlTemplate>
                        </Thumb.Template>
                      </Thumb>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageRightCommand}" Opacity="0" Focusable="False" /></Track.IncreaseRepeatButton>
                  </Track>
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="GhostButton" TargetType="Button">
      <Setter Property="FocusVisualStyle" Value="{StaticResource IpiKeyboardFocusStyle}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="9" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource SidebarHover}" /></Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="LogoNewChatButton" TargetType="Button">
      <Setter Property="FocusVisualStyle" Value="{StaticResource IpiKeyboardFocusStyle}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" HorizontalAlignment="Left">
              <Border x:Name="HoverChrome" Width="88" Height="40" HorizontalAlignment="Left" VerticalAlignment="Center" Background="{DynamicResource SidebarHover}" CornerRadius="7" Opacity="0" />
              <ContentPresenter x:Name="LogoContent" HorizontalAlignment="Left" VerticalAlignment="Center">
                <ContentPresenter.RenderTransform><TranslateTransform Y="0" /></ContentPresenter.RenderTransform>
              </ContentPresenter>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="HoverChrome" Storyboard.TargetProperty="Opacity" To="0.24" Duration="0:0:0.12" />
                      <DoubleAnimation Storyboard.TargetName="LogoContent" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="-1" Duration="0:0:0.12" />
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="HoverChrome" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.16" />
                      <DoubleAnimation Storyboard.TargetName="LogoContent" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.16" />
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.ExitActions>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="HoverChrome" Property="Opacity" Value="0.32" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SideButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="Margin" Value="0,1" />
      <Setter Property="MinHeight" Value="30" />
    </Style>

    <Style x:Key="SidebarHeaderActionText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextDim}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Opacity" Value="0" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
          <Setter Property="Opacity" Value="0.78" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
      <Setter Property="Height" Value="32" />
      <Setter Property="MinWidth" Value="42" />
      <Setter Property="Padding" Value="13,0" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource ControlHoverBg}" /></Trigger>
              <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="{DynamicResource MenuHoverBg}" /></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="MessageActionButton" TargetType="Button">
      <Setter Property="FocusVisualStyle" Value="{StaticResource IpiKeyboardFocusStyle}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="7,0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Height" Value="24" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.82" /></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PluginToggleSwitch" TargetType="ToggleButton">
      <Setter Property="Width" Value="38" />
      <Setter Property="Height" Value="22" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="Track" Background="{DynamicResource Line}" CornerRadius="11">
              <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="{DynamicResource Surface}" HorizontalAlignment="Left" Margin="3,0" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Track" Property="Background" Value="{DynamicResource Accent}" />
                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                <Setter TargetName="Thumb" Property="Fill" Value="White" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Track" Property="Opacity" Value="0.86" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PluginActionButton" TargetType="Button">
      <Setter Property="Height" Value="30" />
      <Setter Property="MinWidth" Value="84" />
      <Setter Property="Padding" Value="11,0" />
      <Setter Property="Background" Value="{DynamicResource RowBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Line}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource SidebarHover}" /></Trigger>
              <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.48" /></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PluginDangerButton" TargetType="Button" BasedOn="{StaticResource PluginActionButton}">
      <Setter Property="MinWidth" Value="82" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#3A9F5A57" />
      <Setter Property="Foreground" Value="#D06A64" />
    </Style>

    <Style x:Key="TitleMenuButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
      <Setter Property="Padding" Value="7,4" />
      <Setter Property="Margin" Value="0,0,7,0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="TitleContextMenu" TargetType="ContextMenu">
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="Background" Value="{DynamicResource PopupBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PopupBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="0,6" />
      <Setter Property="FontFamily" Value="{DynamicResource IpiTextFontFamily}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ContextMenu">
            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
              <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="TitleMenuItem" TargetType="MenuItem">
      <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="MinWidth" Value="270" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontFamily" Value="{DynamicResource IpiTextFontFamily}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="MenuItem">
            <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" TextElement.FontFamily="{DynamicResource IpiTextFontFamily}" TextElement.Foreground="{TemplateBinding Foreground}" />
                <TextBlock Grid.Column="1" Text="{TemplateBinding InputGestureText}" Foreground="{DynamicResource TextMuted}" FontFamily="{DynamicResource IpiTextFontFamily}" Margin="26,0,0,0" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MenuHoverBg}" /></Trigger>
              <Trigger Property="IsEnabled" Value="False"><Setter Property="Foreground" Value="{DynamicResource TextDim}" /></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="TitleMenuSeparator" TargetType="Separator">
      <Setter Property="Background" Value="{DynamicResource PopupDivider}" />
      <Setter Property="Height" Value="1" />
      <Setter Property="Margin" Value="0,6" />
    </Style>

    <Style x:Key="ProjectMenuItem" TargetType="MenuItem">
      <Setter Property="Foreground" Value="{DynamicResource PopupText}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="13,8" />
      <Setter Property="MinWidth" Value="250" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontFamily" Value="{DynamicResource IpiTextFontFamily}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="MenuItem">
            <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="24" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <ContentPresenter ContentSource="Icon" HorizontalAlignment="Left" VerticalAlignment="Center" />
                <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True" TextElement.FontFamily="{DynamicResource IpiTextFontFamily}" TextElement.Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}" Foreground="{DynamicResource TextMuted}" FontFamily="{DynamicResource IpiTextFontFamily}" Margin="24,0,0,0" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MenuHoverBg}" /></Trigger>
              <Trigger Property="IsEnabled" Value="False"><Setter Property="Foreground" Value="{DynamicResource TextDim}" /></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="AttachmentMenuItem" TargetType="MenuItem" BasedOn="{StaticResource ProjectMenuItem}">
      <Setter Property="MinWidth" Value="180" />
      <Setter Property="Padding" Value="12,7" />
    </Style>

    <Style x:Key="RoundIconButton" TargetType="Button">
      <Setter Property="FocusVisualStyle" Value="{StaticResource IpiKeyboardFocusStyle}" />
      <Setter Property="Width" Value="36" />
      <Setter Property="Height" Value="36" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="18">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ComposerIconButton" TargetType="Button">
      <Setter Property="FocusVisualStyle" Value="{StaticResource IpiKeyboardFocusStyle}" />
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource ComposerTextMuted}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="19">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ComposerHoverBg}" />
                <Setter Property="Foreground" Value="{DynamicResource ComposerHoverText}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ComposerPillButton" TargetType="Button">
      <Setter Property="FocusVisualStyle" Value="{StaticResource IpiKeyboardFocusStyle}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource ComposerTextMuted}" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="PillBorder" Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="PillBorder" Property="Background" Value="{DynamicResource ComposerHoverBg}" />
                <Setter Property="Foreground" Value="{DynamicResource ComposerHoverText}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ApprovalMenuOptionButton" TargetType="Button">
      <Setter Property="FocusVisualStyle" Value="{StaticResource IpiKeyboardFocusStyle}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="7,5" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="OptionBorder" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="OptionBorder" Property="Background" Value="{DynamicResource MenuHoverBg}" /></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="CodexSendButton" TargetType="Button">
      <Setter Property="FocusVisualStyle" Value="{StaticResource IpiKeyboardFocusStyle}" />
      <Setter Property="Width" Value="36" />
      <Setter Property="Height" Value="36" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Background" Value="{DynamicResource SendButtonIdleBg}" />
      <Setter Property="Foreground" Value="{DynamicResource SendButtonIdleIcon}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="SendBorder" Background="{TemplateBinding Background}" CornerRadius="18">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                  <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                  <Condition Binding="{Binding DataContext.IsAgentRunning, RelativeSource={RelativeSource TemplatedParent}}" Value="False" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="SendBorder" Property="Background" Value="{DynamicResource SendButtonHoverBg}" />
              </MultiDataTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsAgentRunning}" Value="True">
          <Setter Property="Background" Value="{DynamicResource SendButtonRunningBg}" />
          <Setter Property="Foreground" Value="{DynamicResource SendButtonRunningIcon}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="ChatMessageTitleText" TargetType="TextBlock">
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="Regular" />
      <Setter Property="LineHeight" Value="19.5" />
      <EventSetter Event="Loaded" Handler="ChatMessageText_Loaded" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding Kind}" Value="thinking">
          <Setter Property="FontWeight" Value="Regular" />
          <Setter Property="Opacity" Value="0.95" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="ChatMessageDetailText" TargetType="TextBlock">
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="Foreground" Value="{DynamicResource TextDim}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Regular" />
      <Setter Property="LineHeight" Value="17" />
      <Setter Property="Margin" Value="0,3,0,0" />
      <EventSetter Event="Loaded" Handler="ChatMessageText_Loaded" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding Kind}" Value="thinking">
          <Setter Property="Opacity" Value="0.72" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="ChatSelectableTextBox" TargetType="TextBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="IsReadOnly" Value="True" />
      <Setter Property="IsReadOnlyCaretVisible" Value="True" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="AcceptsReturn" Value="True" />
      <Setter Property="SelectionBrush" Value="{DynamicResource SelectionBrush}" />
      <Setter Property="CaretBrush" Value="{DynamicResource TextDim}" />
      <Setter Property="Focusable" Value="True" />
      <Setter Property="FocusVisualStyle" Value="{StaticResource IpiKeyboardFocusStyle}" />
      <Setter Property="Cursor" Value="IBeam" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" Background="Transparent" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <EventSetter Event="Loaded" Handler="ChatSelectableTextBox_Loaded" />
      <EventSetter Event="MouseUp" Handler="ChatMessageTextSelection_MouseUp" />
      <EventSetter Event="KeyUp" Handler="ChatMessageTextSelection_KeyUp" />
    </Style>

    <DataTemplate x:Key="AttachmentTemplate">
      <Button Style="{StaticResource GhostButton}" Click="AttachmentRemove_Click" Margin="0,0,8,6" ToolTip="{Binding Name}">
        <Grid>
          <Grid Width="98" Height="72" Visibility="{Binding ImageVisibility}" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Border CornerRadius="9">
              <Border.Background>
                <ImageBrush ImageSource="{Binding PreviewPath}" Stretch="UniformToFill" AlignmentX="Center" AlignmentY="Center" />
              </Border.Background>
            </Border>
            <Border CornerRadius="9" BorderBrush="{DynamicResource ComposerChipBorder}" BorderThickness="1" Background="Transparent" />
            <Border Width="18" Height="18" CornerRadius="9" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource ComposerChipBorder}" BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,4,0">
              <TextBlock Text="×" Foreground="{DynamicResource TextMuted}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0" />
            </Border>
          </Grid>
          <Border Visibility="{Binding FileVisibility}" Background="{DynamicResource ComposerChipBg}" BorderBrush="{DynamicResource ComposerChipBorder}" BorderThickness="1" CornerRadius="12" Padding="10,6">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="12" />
              <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextDim}" FontSize="11" Margin="6,0,0,0" />
              <TextBlock Text="×" Foreground="{DynamicResource TextDim}" FontSize="11" Margin="6,0,0,0" />
            </StackPanel>
          </Border>
        </Grid>
      </Button>
    </DataTemplate>

    <DataTemplate x:Key="ChatAttachmentPreviewTemplate">
      <Grid Margin="0,0,7,7" ContextMenuService.IsEnabled="{Binding IsImage}">
        <Grid.ContextMenu>
          <ContextMenu Style="{StaticResource TitleContextMenu}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}" Opened="ChatAttachmentContextMenu_Opened">
            <MenuItem Style="{StaticResource AttachmentMenuItem}" Click="ChatAttachmentCopyImage_Click" />
            <MenuItem Style="{StaticResource AttachmentMenuItem}" Click="ChatAttachmentCopyFile_Click" />
            <Separator Style="{StaticResource TitleMenuSeparator}" />
            <MenuItem Style="{StaticResource AttachmentMenuItem}" Click="ChatAttachmentOpenLocation_Click" />
          </ContextMenu>
        </Grid.ContextMenu>
        <Grid Width="148" Height="104" Visibility="{Binding ImageVisibility}" SnapsToDevicePixels="True" UseLayoutRounding="True">
          <Border CornerRadius="10">
            <Border.Background>
              <ImageBrush ImageSource="{Binding PreviewPath}" Stretch="UniformToFill" AlignmentX="Center" AlignmentY="Center" />
            </Border.Background>
          </Border>
          <Border CornerRadius="10" BorderBrush="{DynamicResource UserBubbleBorder}" BorderThickness="1" Background="Transparent" />
          <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="6" Background="#66000000" CornerRadius="7" Padding="7,3">
            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="10.5" TextTrimming="CharacterEllipsis" MaxWidth="122" />
          </Border>
        </Grid>
        <Border Visibility="{Binding FileVisibility}" Background="{DynamicResource ComposerChipBg}" BorderBrush="{DynamicResource ComposerChipBorder}" BorderThickness="1" CornerRadius="11" Padding="9,6">
          <StackPanel Orientation="Horizontal">
            <local:LucideIcon Icon="paperclip" Size="12" Stroke="{DynamicResource TextMuted}" Margin="0,0,6,0" />
            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="180" />
          </StackPanel>
        </Border>
      </Grid>
    </DataTemplate>

    <Style TargetType="Expander">
      <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
      <Setter Property="FontFamily" Value="{DynamicResource IpiTextFontFamily}" />
      <Setter Property="Margin" Value="0,16,0,0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Expander">
            <StackPanel>
              <ToggleButton x:Name="HeaderSite"
                            IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                            Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                            HorizontalContentAlignment="Stretch">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="HeaderBorder" Background="Transparent" CornerRadius="8" Padding="0">
                      <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="18" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <local:LucideIcon x:Name="ExpanderChevron" Icon="chevron-right" Size="12" Stroke="{DynamicResource TextDim}" VerticalAlignment="Center" HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5">
                          <local:LucideIcon.RenderTransform><RotateTransform Angle="0" /></local:LucideIcon.RenderTransform>
                        </local:LucideIcon>
                        <ContentPresenter Grid.Column="1" Content="{TemplateBinding Content}" HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                      </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="ExpanderChevron" Property="Icon" Value="chevron-down" />
                      </Trigger>
                      <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource SidebarHover}" /></Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </ToggleButton.Template>
                <ContentPresenter ContentSource="Header" />
              </ToggleButton>
              <ContentPresenter x:Name="ExpandSite" ContentSource="Content" ClipToBounds="True" MaxHeight="0" Opacity="0">
                <ContentPresenter.RenderTransform><TranslateTransform Y="-4" /></ContentPresenter.RenderTransform>
              </ContentPresenter>
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsExpanded" Value="True">
                <Setter TargetName="ExpandSite" Property="MaxHeight" Value="5000" />
                <Setter TargetName="ExpandSite" Property="Opacity" Value="1" />
                <Trigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="ExpandSite" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.14">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                      </DoubleAnimation>
                      <DoubleAnimation Storyboard.TargetName="ExpandSite" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-4" To="0" Duration="0:0:0.14">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                      </DoubleAnimation>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.EnterActions>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border x:Name="AppFrame" Background="{DynamicResource GlassShellBg}" BorderBrush="#24A9ADB7" BorderThickness="1" CornerRadius="0" SnapsToDevicePixels="True">
  <Grid x:Name="AppRoot" Background="Transparent" ClipToBounds="True">
    <Grid.RowDefinitions>
      <RowDefinition Height="42" />
      <RowDefinition Height="*" />
      <RowDefinition Height="26" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="{Binding SidebarWidth}" MinWidth="{Binding SidebarMinWidth}" MaxWidth="{Binding SidebarMaxWidth}" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="{Binding RightPanelWidth}" MinWidth="{Binding RightPanelMinWidth}" MaxWidth="{Binding RightPanelMaxWidth}" />
    </Grid.ColumnDefinitions>

    <Border x:Name="TitleBarChrome" Grid.Row="0" Grid.ColumnSpan="3" Background="{DynamicResource GlassTitleBg}" BorderBrush="#2830343D" BorderThickness="0,0,0,1" CornerRadius="0">
      <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
          <Button Style="{StaticResource GhostButton}" Width="34" Height="30" Click="ToggleSidebar_Click" ToolTip="{Binding ToggleSidebarToolTip}" AutomationProperties.Name="{Binding ToggleSidebarToolTip}"><local:LucideIcon Icon="panel-left" Size="15" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
          <Button Style="{StaticResource GhostButton}" Width="34" Height="30" Click="TopBack_Click" ToolTip="{Binding BackToChatToolTip}" AutomationProperties.Name="{Binding BackToChatToolTip}"><local:LucideIcon Icon="arrow-left" Size="15" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
          <Button Style="{StaticResource GhostButton}" Width="34" Height="30" Click="TopForward_Click" ToolTip="{Binding OpenRecentChatToolTip}" AutomationProperties.Name="{Binding OpenRecentChatToolTip}"><local:LucideIcon Icon="arrow-right" Size="15" Stroke="{DynamicResource TextDim}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
          <Button Style="{StaticResource TitleMenuButton}" Click="TopFile_Click" Margin="12,0,7,0">
            <TextBlock Text="{Binding FileMenuText}" Foreground="{DynamicResource TextMuted}" FontSize="13" />
            <Button.ContextMenu>
              <ContextMenu Style="{StaticResource TitleContextMenu}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuNewWindowText}" InputGestureText="Ctrl+Shift+N" Click="FileNewWindow_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuNewChatText}" InputGestureText="Ctrl+N" Click="FileNewChat_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuQuickChatText}" InputGestureText="Alt+Ctrl+N" Click="FileQuickChat_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuOpenFolderText}" InputGestureText="Ctrl+O" Click="OpenActiveLocation_Click" />
              </ContextMenu>
            </Button.ContextMenu>
          </Button>
          <Button Style="{StaticResource TitleMenuButton}" Click="TopEdit_Click">
            <TextBlock Text="{Binding EditMenuText}" Foreground="{DynamicResource TextMuted}" FontSize="13" />
            <Button.ContextMenu>
              <ContextMenu Style="{StaticResource TitleContextMenu}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuUndoText}" InputGestureText="Ctrl+Z" Command="ApplicationCommands.Undo" />
                <Separator Style="{StaticResource TitleMenuSeparator}" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuCutText}" InputGestureText="Ctrl+X" Command="ApplicationCommands.Cut" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuCopyText}" InputGestureText="Ctrl+C" Command="ApplicationCommands.Copy" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuPasteText}" InputGestureText="Ctrl+V" Command="ApplicationCommands.Paste" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuSelectAllText}" InputGestureText="Ctrl+A" Command="ApplicationCommands.SelectAll" />
              </ContextMenu>
            </Button.ContextMenu>
          </Button>
          <Button Style="{StaticResource TitleMenuButton}" Click="TopView_Click">
            <TextBlock Text="{Binding ViewMenuText}" Foreground="{DynamicResource TextMuted}" FontSize="13" />
            <Button.ContextMenu>
              <ContextMenu Style="{StaticResource TitleContextMenu}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuToggleSidebarText}" InputGestureText="Ctrl+B" Click="ViewToggleSidebar_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuToggleBottomPanelText}" InputGestureText="Ctrl+J" Click="ViewToggleBottomPanel_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuTogglePinnedSummaryText}" Click="ViewTogglePinnedSummary_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuOpenTerminalText}" InputGestureText="Ctrl+`" Click="ViewOpenTerminal_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuToggleFileTreeText}" InputGestureText="Ctrl+Shift+E" Click="ViewToggleFileTree_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuOpenBrowserTabText}" InputGestureText="Ctrl+T" Click="ViewOpenBrowserTab_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuFocusBrowserAddressBarText}" Click="ViewFocusBrowserAddressBar_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuReloadBrowserPageText}" InputGestureText="Ctrl+R" Click="ViewReloadBrowserPage_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuToggleSidePanelText}" InputGestureText="Alt+Ctrl+B" Click="ViewToggleSidePanel_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuFindText}" InputGestureText="Ctrl+F" Click="ViewFind_Click" />
                <Separator Style="{StaticResource TitleMenuSeparator}" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuPreviousChatText}" InputGestureText="Ctrl+Shift+[" Click="ViewPreviousChat_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuNextChatText}" InputGestureText="Ctrl+Shift+]" Click="ViewNextChat_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuBackText}" InputGestureText="Ctrl+[" Click="ViewBack_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuForwardText}" InputGestureText="Ctrl+]" Click="ViewForward_Click" />
                <Separator Style="{StaticResource TitleMenuSeparator}" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuZoomInText}" InputGestureText="Ctrl+Shift+=" Click="ViewZoomIn_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuZoomOutText}" InputGestureText="Ctrl+-" Click="ViewZoomOut_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuActualSizeText}" InputGestureText="Ctrl+0" Click="ViewActualSize_Click" />
                <Separator Style="{StaticResource TitleMenuSeparator}" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="{Binding MenuToggleFullScreenText}" InputGestureText="F11" Click="ViewToggleFullScreen_Click" />
              </ContextMenu>
            </Button.ContextMenu>
          </Button>
          <Button Style="{StaticResource TitleMenuButton}" Click="TopHelp_Click" Visibility="Collapsed">
            <TextBlock Text="{Binding HelpMenuText}" Foreground="{DynamicResource TextMuted}" FontSize="13" />
            <Button.ContextMenu>
              <ContextMenu Style="{StaticResource TitleContextMenu}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="System" Click="ViewSystem_Click" />
                <MenuItem Style="{StaticResource TitleMenuItem}" Header="About ipi" Click="HelpAbout_Click" />
              </ContextMenu>
            </Button.ContextMenu>
          </Button>
          <Border Width="0" Height="24" Background="Transparent" Margin="0,0,8,0" />
          <Button Style="{StaticResource GhostButton}" Width="38" Height="30" Click="Appearance_Click" ToolTip="{Binding ToggleThemeToolTip}" AutomationProperties.Name="{Binding ToggleThemeToolTip}"><local:LucideIcon Icon="{Binding AppearanceIcon}" Size="15" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
          <Button Style="{StaticResource ToolbarButton}" Click="TopExport_Click"><StackPanel Orientation="Horizontal"><local:LucideIcon Icon="download" Size="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,7,0" /><TextBlock Text="{Binding ExportText}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="12" /></StackPanel></Button>
          <Grid x:Name="BranchPickerHost" Visibility="Collapsed">
            <Button Style="{StaticResource ToolbarButton}" Click="TopBranches_Click">
              <StackPanel Orientation="Horizontal">
                <local:LucideIcon Icon="git-branch" Size="14" Stroke="#6D8DFF" Margin="0,0,6,0" />
                <TextBlock Text="{Binding BranchesText}" Foreground="{DynamicResource TextPrimary}" FontSize="12" />
              </StackPanel>
            </Button>
            <Popup PlacementTarget="{Binding ElementName=BranchPickerHost}" Placement="Bottom" VerticalOffset="8" AllowsTransparency="True" StaysOpen="False" IsOpen="{Binding IsBranchPickerOpen, Mode=TwoWay}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
              <Border Width="410" MinHeight="260" MaxHeight="520" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="14" Padding="14" Effect="{x:Null}">
                <StackPanel>
                  <Border Height="36" Background="{DynamicResource RowBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="8" Padding="10,0" Margin="0,0,0,14">
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="22" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <local:LucideIcon Icon="search" Size="15" Stroke="{DynamicResource TextDim}" VerticalAlignment="Center" />
                      <Grid Grid.Column="1">
                        <TextBlock Text="{Binding BranchSearchPlaceholder}" Foreground="{DynamicResource TextDim}" FontSize="13" VerticalAlignment="Center" IsHitTestVisible="False">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding BranchSearchText}" Value=""><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding BranchSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource CaretBrush}" SelectionBrush="{DynamicResource SelectionBrush}" FontSize="13" VerticalContentAlignment="Center" />
                      </Grid>
                    </Grid>
                  </Border>

                  <TextBlock Text="{Binding BranchesText}" Foreground="{DynamicResource TextMuted}" FontSize="13" FontWeight="Medium" Margin="2,0,0,10" />
                  <TextBlock Text="{Binding BranchStatusText}" Foreground="{DynamicResource TextDim}" FontSize="12" Margin="2,0,0,8" TextTrimming="CharacterEllipsis" />

                  <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding BranchItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Style="{StaticResource GhostButton}" Click="BranchItem_Click" Padding="0" Margin="0,0,0,4">
                            <Grid MinHeight="48" Margin="6,0">
                              <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /><ColumnDefinition Width="28" /></Grid.ColumnDefinitions>
                              <local:LucideIcon Icon="git-branch" Size="15" Stroke="{DynamicResource TextMuted}" VerticalAlignment="Center" />
                              <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextDim}" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                              </StackPanel>
                              <TextBlock Grid.Column="2" Text="{Binding SelectedMark}" Foreground="{DynamicResource TextPrimary}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <Border Height="1" Background="{DynamicResource PopupDivider}" Margin="0,14,0,10" />
                  <Button Style="{StaticResource GhostButton}" Click="BranchCreate_Click" IsEnabled="{Binding CanCreateBranch}" Padding="0">
                    <Grid Height="36" Margin="6,0">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <local:LucideIcon Icon="plus" Size="16" Stroke="{DynamicResource TextMuted}" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding BranchCreateLabel}" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </Grid>
                  </Button>
                </StackPanel>
              </Border>
            </Popup>
          </Grid>
          <Button Style="{StaticResource ToolbarButton}" Click="TopSystem_Click"><StackPanel Orientation="Horizontal"><local:LucideIcon Icon="terminal-square" Size="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,7,0" /><TextBlock Text="{Binding SystemText}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="12" /></StackPanel></Button>
          <Grid x:Name="UpdateIndicatorHost" Visibility="{Binding UpdateButtonVisibility}" Margin="4,0,0,0">
            <Button Style="{StaticResource ToolbarButton}" Click="UpdateIndicator_Click" Padding="8,5" ToolTip="{Binding UpdateStatusText}">
              <StackPanel Orientation="Horizontal">
                <Border Width="7" Height="7" CornerRadius="3.5" Background="{DynamicResource FeedbackAccent}" Margin="0,0,7,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding UpdateAvailableText}" Foreground="{DynamicResource TextPrimary}" FontSize="12" />
              </StackPanel>
            </Button>
            <Popup PlacementTarget="{Binding ElementName=UpdateIndicatorHost}" Placement="Bottom" VerticalOffset="8" AllowsTransparency="True" StaysOpen="False" IsOpen="{Binding IsUpdatePopupOpen, Mode=TwoWay}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
              <Border Width="330" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="14" Padding="14">
                <StackPanel>
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource FeedbackAccent}" Opacity="0.18" HorizontalAlignment="Left" VerticalAlignment="Top">
                      <local:LucideIcon Icon="refresh-cw" Size="13" Stroke="{DynamicResource FeedbackAccent}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="{Binding UpdatePopupTitle}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding UpdateStatusText}" Foreground="{DynamicResource FeedbackAccent}" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                  </Grid>
                  <TextBlock Text="{Binding UpdatePopupDescription}" Foreground="{DynamicResource TextMuted}" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,2,0,10" />
                  <TextBlock Text="{Binding UpdateDetailText}" Foreground="{DynamicResource TextDim}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12" />
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource GhostButton}" Click="UpdateRefresh_Click" Padding="10,6" Margin="0,0,8,0"><TextBlock Text="{Binding RefreshLocalDataToolTip}" Foreground="{DynamicResource TextMuted}" FontSize="12" /></Button>
                    <Button Style="{StaticResource ToolbarButton}" Click="UpdateNow_Click" IsEnabled="{Binding CanApplyUpdate}" Padding="12,6"><TextBlock Text="{Binding UpdateActionText}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="12" FontWeight="SemiBold" /></Button>
                  </StackPanel>
                </StackPanel>
              </Border>
            </Popup>
          </Grid>
        </StackPanel>
        <Border Grid.Column="1" Background="Transparent" />
        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
          <Button x:Name="NotificationSoundButton" Style="{StaticResource GhostButton}" Width="38" Height="42" Click="NotificationSound_Click"><local:LucideIcon x:Name="NotificationSoundIcon" Icon="volume-2" Size="15" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
          <Button Style="{StaticResource GhostButton}" Width="38" Height="42" Click="FileSettings_Click" ToolTip="{Binding SettingsToolTip}" AutomationProperties.Name="{Binding SettingsToolTip}"><local:LucideIcon Icon="sliders-horizontal" Size="15" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
          <Button Style="{StaticResource GhostButton}" Width="38" Height="42" Click="ToggleRightPanel_Click" ToolTip="{Binding ToggleRightPanelToolTip}" AutomationProperties.Name="{Binding ToggleRightPanelToolTip}"><local:LucideIcon Icon="panel-right" Size="15" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
          <Button Style="{StaticResource GhostButton}" Width="46" Height="42" Click="Minimize_Click" AutomationProperties.Name="Minimize"><local:LucideIcon Icon="minus" Size="15" Stroke="{DynamicResource TextPrimary}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
          <Button Style="{StaticResource GhostButton}" Width="46" Height="42" Click="MaximizeRestore_Click" AutomationProperties.Name="Maximize or restore"><local:LucideIcon Icon="maximize" Size="14" Stroke="{DynamicResource TextPrimary}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
          <Button Style="{StaticResource GhostButton}" Width="46" Height="42" Click="Close_Click" AutomationProperties.Name="Close"><local:LucideIcon Icon="x" Size="15" Stroke="{DynamicResource TextPrimary}" HorizontalAlignment="Center" IsHitTestVisible="False" /></Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border x:Name="SidebarPanel" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Width="{Binding SidebarPanelWidth}" HorizontalAlignment="Left"
            Background="{DynamicResource SidebarBg}" BorderBrush="Transparent" BorderThickness="0"
            Visibility="{Binding SidebarPanelVisibility}" IsHitTestVisible="{Binding SidebarPanelIsHitTestVisible}"
            MouseEnter="SidebarPanel_MouseEnter" MouseLeave="SidebarPanel_MouseLeave" Panel.ZIndex="80">
      <Border.RenderTransform>
        <TranslateTransform x:Name="SidebarPanelTranslate" />
      </Border.RenderTransform>
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="22,20,18,8" Visibility="{Binding ExpandedSidebarVisibility}">
          <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource LogoNewChatButton}" Click="LogoNewChat_Click" HorizontalAlignment="Left" Width="92" Height="48" Padding="0" ToolTip="{Binding MenuNewChatText}">
              <Grid>
                <Rectangle Width="82" Height="44" Fill="{DynamicResource TextPrimary}" HorizontalAlignment="Left" VerticalAlignment="Center">
                  <Rectangle.OpacityMask>
                    <ImageBrush ImageSource="Assets/Brand/export/black/ipi-word-black.png" Stretch="Uniform" />
                  </Rectangle.OpacityMask>
                </Rectangle>
              </Grid>
            </Button>
            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Click="Connect_Click" Width="30" Height="30">
              <local:LucideIcon Icon="refresh-cw" Size="14" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" />
            </Button>
          </Grid>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="{Binding ExpandedSidebarVisibility}">
          <ScrollViewer.Resources>
            <Style TargetType="{x:Type ScrollBar}">
              <Setter Property="Width" Value="8" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Background="Transparent" Width="{TemplateBinding Width}">
                      <Track x:Name="PART_Track" IsDirectionReversed="True">
                        <Track.DecreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="False" /></Track.DecreaseRepeatButton>
                        <Track.Thumb>
                          <Thumb MinHeight="42" Background="#5C636D" Focusable="False">
                            <Thumb.Template>
                              <ControlTemplate TargetType="{x:Type Thumb}">
                                <Border Width="4" HorizontalAlignment="Center" Background="{TemplateBinding Background}" CornerRadius="2" Opacity="0.62" />
                              </ControlTemplate>
                            </Thumb.Template>
                          </Thumb>
                        </Track.Thumb>
                        <Track.IncreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="False" /></Track.IncreaseRepeatButton>
                      </Track>
                    </Grid>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ScrollViewer.Resources>
          <StackPanel Margin="22,8,14,28">
            <Expander IsExpanded="{Binding IsProjectsExpanded, Mode=TwoWay}">
              <Expander.Header>
                <Grid x:Name="ProjectsHeader" Width="{Binding SidebarHeaderWidth}" Height="30" Background="Transparent">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding ProjectsText}" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center" />
                  <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel.Style>
                      <Style TargetType="StackPanel">
                        <Setter Property="Opacity" Value="0" />
                        <Setter Property="IsHitTestVisible" Value="False" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsMouseOver, ElementName=ProjectsHeader}" Value="True">
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="IsHitTestVisible" Value="True" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=ProjectsHeader}" Value="True">
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="IsHitTestVisible" Value="True" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </StackPanel.Style>
                    <Button Style="{StaticResource GhostButton}" Width="24" Height="24" Padding="0" Margin="0,0,6,0" Click="SidebarProjectsMenu_Click" ToolTip="{Binding ProjectActionsText}">
                      <local:LucideIcon Icon="more-horizontal" Size="14" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      <Button.ContextMenu>
                        <ContextMenu Style="{StaticResource TitleContextMenu}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                          <MenuItem Header="{Binding SidebarArchiveAllChatsText}" Foreground="{DynamicResource PopupText}" Background="Transparent" Padding="14,8" FontSize="13" Click="HeaderArchiveAllChats_Click"></MenuItem>
                          <Separator Style="{StaticResource TitleMenuSeparator}" />
                          <MenuItem Header="{Binding SidebarOrganizeByProjectText}" Foreground="{DynamicResource PopupText}" Background="Transparent" Padding="14,8" FontSize="13" Click="HeaderOrganizeByProject_Click"></MenuItem>
                          <MenuItem Header="{Binding SidebarRecentProjectsText}" Foreground="{DynamicResource PopupText}" Background="Transparent" Padding="14,8" FontSize="13" Click="HeaderRecentProjects_Click"></MenuItem>
                          <Separator Style="{StaticResource TitleMenuSeparator}" />
                          <MenuItem Header="{Binding SidebarSortChronologicalText}" Foreground="{DynamicResource PopupText}" Background="Transparent" Padding="14,8" FontSize="13" Click="HeaderSortChronological_Click"></MenuItem>
                          <MenuItem Header="{Binding SidebarSortRecentText}" Foreground="{DynamicResource PopupText}" Background="Transparent" Padding="14,8" FontSize="13" Click="HeaderSortRecent_Click"></MenuItem>
                        </ContextMenu>
                      </Button.ContextMenu>
                    </Button>
                    <Button Style="{StaticResource GhostButton}" Width="24" Height="24" Padding="0" Click="SidebarProjectNew_Click" ToolTip="{Binding NewProjectText}">
                      <local:LucideIcon Icon="plus" Size="13" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                  </StackPanel>
                </Grid>
              </Expander.Header>
              <StackPanel Margin="0,8,0,0">
                <ItemsControl ItemsSource="{Binding ProjectGroups}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Margin="0,0,0,8">
                        <Grid x:Name="ProjectRow" Width="{Binding DataContext.SidebarRowWidth, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Left">
                          <Button Style="{StaticResource SideButton}" Click="Nav_Click" Width="{Binding DataContext.SidebarRowWidth, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Left" Padding="8,6">
                            <Grid>
                              <Grid.ColumnDefinitions><ColumnDefinition Width="26" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                              <local:LucideIcon Icon="folder" Size="14" Stroke="{DynamicResource TextMuted}" VerticalAlignment="Top" Margin="0,2,0,0" />
                              <StackPanel Grid.Column="1" Margin="0,0,54,0">
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Path}" Foreground="{DynamicResource TextDim}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                              </StackPanel>
                            </Grid>
                          </Button>
                          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,6,0">
                            <StackPanel.Style>
                              <Style TargetType="StackPanel">
                                <Setter Property="Opacity" Value="0" />
                                <Setter Property="IsHitTestVisible" Value="False" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsMouseOver, ElementName=ProjectRow}" Value="True"><Setter Property="Opacity" Value="1" /><Setter Property="IsHitTestVisible" Value="True" /></DataTrigger>
                                  <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=ProjectRow}" Value="True"><Setter Property="Opacity" Value="1" /><Setter Property="IsHitTestVisible" Value="True" /></DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </StackPanel.Style>
                            <Button Style="{StaticResource GhostButton}" Width="24" Height="24" Padding="0" Click="ProjectMenu_Click" ToolTip="{Binding DataContext.ProjectActionsText, RelativeSource={RelativeSource AncestorType=Window}}" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                              <local:LucideIcon Icon="more-horizontal" Size="14" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" />
                              <Button.ContextMenu>
                                <ContextMenu Style="{StaticResource TitleContextMenu}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}" Tag="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                  <MenuItem Style="{StaticResource ProjectMenuItem}" Header="{Binding Tag.ProjectPinText, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Click="ProjectPin_Click">
                                    <MenuItem.Icon><local:LucideIcon Icon="pin" Size="15" Stroke="{DynamicResource TextMuted}" /></MenuItem.Icon>
                                  </MenuItem>
                                  <MenuItem Style="{StaticResource ProjectMenuItem}" Header="{Binding Tag.ProjectOpenExplorerText, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Click="ProjectOpenExplorer_Click">
                                    <MenuItem.Icon><local:LucideIcon Icon="folder" Size="15" Stroke="{DynamicResource TextMuted}" /></MenuItem.Icon>
                                  </MenuItem>
                                  <MenuItem Style="{StaticResource ProjectMenuItem}" Header="{Binding Tag.ProjectCreateWorktreeText, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Click="ProjectCreateWorktree_Click" IsEnabled="{Binding CanCreateWorktree}">
                                    <MenuItem.Icon><local:LucideIcon Icon="git-branch" Size="15" Stroke="{DynamicResource TextMuted}" /></MenuItem.Icon>
                                  </MenuItem>
                                  <MenuItem Style="{StaticResource ProjectMenuItem}" Header="{Binding Tag.ProjectRenameText, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Click="ProjectRename_Click">
                                    <MenuItem.Icon><local:LucideIcon Icon="edit-3" Size="15" Stroke="{DynamicResource TextMuted}" /></MenuItem.Icon>
                                  </MenuItem>
                                  <Separator Style="{StaticResource TitleMenuSeparator}" />
                                  <MenuItem Style="{StaticResource ProjectMenuItem}" Header="{Binding Tag.ProjectNewChatText, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Click="ProjectNewChat_Click">
                                    <MenuItem.Icon><local:LucideIcon Icon="message-square" Size="15" Stroke="{DynamicResource TextMuted}" /></MenuItem.Icon>
                                  </MenuItem>
                                  <Separator Style="{StaticResource TitleMenuSeparator}" />
                                  <MenuItem Style="{StaticResource ProjectMenuItem}" Header="{Binding Tag.ProjectRemoveText, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Click="ProjectArchive_Click">
                                    <MenuItem.Icon><local:LucideIcon Icon="x" Size="15" Stroke="{DynamicResource TextMuted}" /></MenuItem.Icon>
                                  </MenuItem>
                                </ContextMenu>
                              </Button.ContextMenu>
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Width="24" Height="24" Padding="0" Click="ProjectNewChat_Click" ToolTip="{Binding DataContext.ProjectNewChatText, RelativeSource={RelativeSource AncestorType=Window}}">
                              <local:LucideIcon Icon="edit-3" Size="13" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" />
                            </Button>
                          </StackPanel>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Sessions}" Margin="28,2,0,0">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Grid x:Name="NestedSessionRow" Width="{Binding DataContext.SidebarNestedRowWidth, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Left" Margin="0,0,0,1">
                                <Button Style="{StaticResource SideButton}" Click="Nav_Click" Padding="4,5" Width="{Binding DataContext.SidebarNestedRowWidth, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Left">
                                  <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="18" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <local:LucideIcon Icon="{Binding Icon}" Size="13" Stroke="{DynamicResource TextDim}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="13" Foreground="{DynamicResource TextMuted}" TextTrimming="CharacterEllipsis" Margin="0,0,48,0" />
                                    <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="{DynamicResource TextDim}" FontSize="10" Margin="8,0,0,0" HorizontalAlignment="Right">
                                      <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                          <Setter Property="Visibility" Value="Visible" />
                                          <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=NestedSessionRow}" Value="True">
                                              <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                          </Style.Triggers>
                                        </Style>
                                      </TextBlock.Style>
                                    </TextBlock>
                                  </Grid>
                                </Button>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0">
                                  <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Opacity" Value="0" /><Setter Property="IsHitTestVisible" Value="False" /><Style.Triggers><DataTrigger Binding="{Binding IsMouseOver, ElementName=NestedSessionRow}" Value="True"><Setter Property="Opacity" Value="1" /><Setter Property="IsHitTestVisible" Value="True" /></DataTrigger><DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=NestedSessionRow}" Value="True"><Setter Property="Opacity" Value="1" /><Setter Property="IsHitTestVisible" Value="True" /></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                                  <Button Style="{StaticResource GhostButton}" Width="22" Height="22" Padding="0" Click="SessionPin_Click" ToolTip="Pin chat"><local:LucideIcon Icon="pin" Size="13" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" /></Button>
                                  <Button Style="{StaticResource GhostButton}" Width="22" Height="22" Padding="0" Click="SessionArchive_Click" ToolTip="Archive chat"><local:LucideIcon Icon="archive" Size="13" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" /></Button>
                                </StackPanel>
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Expander>

            <Expander IsExpanded="{Binding IsSessionsExpanded, Mode=TwoWay}">
              <Expander.Header>
                <Grid x:Name="ConversationsHeader" Width="{Binding SidebarHeaderWidth}" Height="30" Background="Transparent">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding ConversationsText}" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center" />
                  <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel.Style>
                      <Style TargetType="StackPanel">
                        <Setter Property="Opacity" Value="0" />
                        <Setter Property="IsHitTestVisible" Value="False" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsMouseOver, ElementName=ConversationsHeader}" Value="True">
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="IsHitTestVisible" Value="True" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=ConversationsHeader}" Value="True">
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="IsHitTestVisible" Value="True" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </StackPanel.Style>
                    <Button Style="{StaticResource GhostButton}" Width="24" Height="24" Padding="0" Margin="0,0,6,0" Click="SidebarConversationsMenu_Click" ToolTip="{Binding ProjectActionsText}">
                      <local:LucideIcon Icon="more-horizontal" Size="14" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      <Button.ContextMenu>
                        <ContextMenu Style="{StaticResource TitleContextMenu}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                          <MenuItem Header="{Binding SidebarArchiveAllChatsText}" Foreground="{DynamicResource PopupText}" Background="Transparent" Padding="14,8" FontSize="13" Click="HeaderArchiveAllChats_Click"></MenuItem>
                          <Separator Style="{StaticResource TitleMenuSeparator}" />
                          <MenuItem Header="{Binding SidebarOrganizeByProjectText}" Foreground="{DynamicResource PopupText}" Background="Transparent" Padding="14,8" FontSize="13" Click="HeaderOrganizeByProject_Click"></MenuItem>
                          <MenuItem Header="{Binding SidebarRecentProjectsText}" Foreground="{DynamicResource PopupText}" Background="Transparent" Padding="14,8" FontSize="13" Click="HeaderRecentProjects_Click"></MenuItem>
                          <Separator Style="{StaticResource TitleMenuSeparator}" />
                          <MenuItem Header="{Binding SidebarSortChronologicalText}" Foreground="{DynamicResource PopupText}" Background="Transparent" Padding="14,8" FontSize="13" Click="HeaderSortChronological_Click"></MenuItem>
                          <MenuItem Header="{Binding SidebarSortRecentText}" Foreground="{DynamicResource PopupText}" Background="Transparent" Padding="14,8" FontSize="13" Click="HeaderSortRecent_Click"></MenuItem>
                        </ContextMenu>
                      </Button.ContextMenu>
                    </Button>
                    <Button Style="{StaticResource GhostButton}" Width="24" Height="24" Padding="0" Click="SidebarDefaultChatNew_Click" ToolTip="{Binding DefaultChatNoProjectText}">
                      <local:LucideIcon Icon="edit-3" Size="13" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                  </StackPanel>
                </Grid>
              </Expander.Header>
              <StackPanel Margin="0,8,0,0">
                <ItemsControl ItemsSource="{Binding Sessions}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid x:Name="SessionRow" Width="{Binding DataContext.SidebarRowWidth, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Left">
                        <Button Style="{StaticResource SideButton}" Click="Nav_Click" Width="{Binding DataContext.SidebarRowWidth, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Left">
                          <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="18" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <local:LucideIcon Icon="{Binding Icon}" Size="13" Stroke="{DynamicResource TextDim}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="13" Foreground="{DynamicResource TextMuted}" TextTrimming="CharacterEllipsis" Margin="0,0,50,0" />
                            <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="{DynamicResource TextDim}" FontSize="10" Margin="10,0,0,0" HorizontalAlignment="Right">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Visibility" Value="Visible" />
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=SessionRow}" Value="True">
                                      <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>
                          </Grid>
                        </Button>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0">
                          <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Opacity" Value="0" /><Setter Property="IsHitTestVisible" Value="False" /><Style.Triggers><DataTrigger Binding="{Binding IsMouseOver, ElementName=SessionRow}" Value="True"><Setter Property="Opacity" Value="1" /><Setter Property="IsHitTestVisible" Value="True" /></DataTrigger><DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=SessionRow}" Value="True"><Setter Property="Opacity" Value="1" /><Setter Property="IsHitTestVisible" Value="True" /></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                          <Button Style="{StaticResource GhostButton}" Width="22" Height="22" Padding="0" Click="SessionPin_Click" ToolTip="Pin chat"><local:LucideIcon Icon="pin" Size="13" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" /></Button>
                          <Button Style="{StaticResource GhostButton}" Width="22" Height="22" Padding="0" Click="SessionArchive_Click" ToolTip="Archive chat"><local:LucideIcon Icon="archive" Size="13" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" /></Button>
                        </StackPanel>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Expander>

          </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Margin="14,0,14,14" Visibility="{Binding ExpandedSidebarVisibility}" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
          <Expander IsExpanded="{Binding IsExplorerExpanded, Mode=TwoWay}">
            <Expander.Header>
              <Grid Width="{Binding SidebarHeaderWidth}" Height="28">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ExplorerText}" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center" />
                <Button Grid.Column="2" Style="{StaticResource GhostButton}" Width="26" Height="24" Padding="0" Click="ExplorerRefresh_Click" ToolTip="Refresh explorer">
                  <local:LucideIcon Icon="refresh-cw" Size="13" Stroke="{DynamicResource TextDim}" HorizontalAlignment="Center" />
                </Button>
              </Grid>
            </Expander.Header>
            <Border MaxHeight="260" Margin="0,6,0,0">
              <TreeView ItemsSource="{Binding ExplorerRoots}" SelectedItemChanged="ExplorerTree_SelectedItemChanged" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource ExplorerTreeItemStyle}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <TreeView.Resources>
                  <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource IpiThinScrollBar}" />
                </TreeView.Resources>
              </TreeView>
            </Border>
          </Expander>
        </Border>

        <StackPanel Grid.RowSpan="3" Margin="10,34,10,18" Visibility="{Binding CollapsedSidebarVisibility}">
          <Button Style="{StaticResource GhostButton}" Click="Connect_Click" Width="38" Height="38" Margin="0,0,0,10" ToolTip="{Binding RefreshLocalDataToolTip}">
            <local:LucideIcon Icon="refresh-cw" Size="16" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" />
          </Button>
          <ItemsControl ItemsSource="{Binding PrimaryNav}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Style="{StaticResource GhostButton}" Click="Nav_Click" Width="38" Height="38" Margin="0,0,0,8">
                  <local:LucideIcon Icon="{Binding Icon}" Size="16" Stroke="{DynamicResource TextMuted}" HorizontalAlignment="Center" />
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Grid>
    </Border>

    <Thumb x:Name="SidebarResizeThumb" Grid.Row="1"
           Grid.Column="0"
           Grid.ColumnSpan="3"
           Width="14"
           Margin="{Binding SidebarResizeThumbMargin}"
           HorizontalAlignment="Left"
           VerticalAlignment="Stretch"
           Cursor="SizeWE"
           Visibility="{Binding SidebarResizeThumbVisibility}"
           Panel.ZIndex="120"
           MouseEnter="SidebarResizeThumb_MouseEnter"
           MouseMove="SidebarResizeThumb_MouseMove"
           MouseLeave="SidebarResizeThumb_MouseLeave"
           DragStarted="SidebarResizeThumb_DragStarted"
           DragDelta="SidebarResizeThumb_DragDelta"
           DragCompleted="SidebarResizeThumb_DragCompleted">
      <Thumb.Template>
        <ControlTemplate TargetType="{x:Type Thumb}">
          <Border Background="#01000000" />
        </ControlTemplate>
      </Thumb.Template>
    </Thumb>

    <Border x:Name="SidebarResizeCursor" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
            Width="9" Height="34" CornerRadius="4.5" HorizontalAlignment="Left" VerticalAlignment="Top"
            Margin="0"
            Background="#DFFFFFFF"
            BorderBrush="#66000000" BorderThickness="1"
            Visibility="Collapsed"
            IsHitTestVisible="False" Opacity="0" Panel.ZIndex="130">
      <Grid>
        <Border Width="1" Height="20" Background="#AA000000" HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Border Grid.Row="0"
            Grid.RowSpan="3"
            Grid.ColumnSpan="3"
            Width="14"
            HorizontalAlignment="Left"
            Background="#01000000"
            Visibility="{Binding SidebarAutoHideEdgeVisibility}"
            MouseEnter="SidebarEdge_MouseEnter"
            MouseMove="SidebarEdge_MouseEnter"
            Panel.ZIndex="100" />

    <Grid Grid.Row="1" Grid.Column="1" Margin="46,38,46,22" Visibility="{Binding MainPanelVisibility}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="12" Padding="10,8" Margin="0,0,0,18" MaxWidth="1060" HorizontalAlignment="Stretch"
              Visibility="Collapsed">
        <Grid MaxWidth="1060">
          <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal">
            <Button Style="{StaticResource ToolbarButton}" Click="ReturnToChat_Click" Visibility="{Binding ReturnToChatVisibility}" Margin="0,0,16,0">
              <TextBlock Text="{Binding ReturnToChatText}" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold" />
