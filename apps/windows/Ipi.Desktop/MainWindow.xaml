          <Grid VerticalAlignment="Center">
            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="38" /><RowDefinition Height="0" /></Grid.RowDefinitions>
            <ItemsControl ItemsSource="{Binding Attachments}" Margin="0,0,0,8">
              <ItemsControl.Style>
                <Style TargetType="ItemsControl">
                  <Setter Property="Visibility" Value="Visible" />
                  <Style.Triggers>
                    <Trigger Property="HasItems" Value="False"><Setter Property="Visibility" Value="Collapsed" /></Trigger>
                  </Style.Triggers>
                </Style>
              </ItemsControl.Style>
              <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <StaticResource ResourceKey="AttachmentTemplate" />
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Grid Grid.Row="1">
              <TextBlock Text="{Binding PromptPlaceholderText}" Visibility="{Binding PromptPlaceholderVisibility}" IsHitTestVisible="False"
                         Foreground="{DynamicResource ComposerTextMuted}" FontSize="14" FontWeight="Regular" Margin="44,0,320,0" VerticalAlignment="Center" />
              <TextBox x:Name="MainPromptBox" Text="{Binding PromptText, UpdateSourceTrigger=PropertyChanged}" PreviewKeyDown="PromptBox_KeyDown" DataObject.Pasting="PromptBox_Pasting"
                       Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ComposerTextPrimary}" CaretBrush="{DynamicResource ComposerCaretBrush}" Padding="0"
                       FontSize="14" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Hidden" Margin="44,0,320,0" VerticalAlignment="Center" VerticalContentAlignment="Center"
                       AutomationProperties.Name="Message" AutomationProperties.HelpText="Press Enter to send. Press Shift+Enter for a new line." />
            </Grid>
            <Grid Grid.Row="1" VerticalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Button Grid.Column="0" Style="{StaticResource ComposerIconButton}" Width="30" Height="30" Click="AddFile_Click" Margin="0,0,8,0" ToolTip="{Binding AddFileToolTip}" AutomationProperties.Name="{Binding AddFileToolTip}">
                <local:LucideIcon Icon="plus" Size="15" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
              </Button>

              <Grid Grid.Column="2" x:Name="MainApprovalPickerHost" Margin="0,0,10,0" Visibility="Collapsed">
                <Button Style="{StaticResource ComposerPillButton}" Click="MainApproval_Click">
                  <StackPanel Orientation="Horizontal">
                    <local:LucideIcon Icon="shield-check" Size="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding ApprovalLabel}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="13" FontWeight="Medium" />
                    <local:LucideIcon Icon="chevron-down" Size="13" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="7,1,0,0" />
                  </StackPanel>
                </Button>
                <Popup PlacementTarget="{Binding ElementName=MainApprovalPickerHost}" Placement="Top" VerticalOffset="-8" AllowsTransparency="True" StaysOpen="False" IsOpen="{Binding IsMainApprovalPickerOpen, Mode=TwoWay}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                  <Border Width="392" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="14" Padding="10,9">
                    <StackPanel>
                      <StackPanel Orientation="Horizontal" Margin="6,0,6,6">
                        <TextBlock Text="{Binding ApprovalQuestionText}" Foreground="{DynamicResource TextMuted}" FontSize="13" FontWeight="Medium" />
                      </StackPanel>
                      <ItemsControl ItemsSource="{Binding ApprovalOptions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Button Style="{StaticResource ApprovalMenuOptionButton}" Click="ApprovalOption_Click" IsEnabled="{Binding IsEnabled}">
                              <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /><ColumnDefinition Width="22" /></Grid.ColumnDefinitions>
                                <local:LucideIcon Icon="{Binding Icon}" Size="15" Stroke="#C8C9CE" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0" />
                                <StackPanel Grid.Column="1">
                                  <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Medium" />
                                  <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextDim}" FontSize="12" TextWrapping="Wrap" Margin="0,1,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding SelectedMark}" Foreground="{DynamicResource TextPrimary}" FontSize="17" VerticalAlignment="Center" HorizontalAlignment="Center" />
                              </Grid>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </Popup>
              </Grid>

              <local:LucideIcon Grid.Column="3" Icon="clock" Visibility="Collapsed" Size="16" Stroke="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,18,0" />
              <Grid Grid.Column="4" x:Name="MainThinkingPickerHost" Margin="0,0,8,0">
                <Button Style="{StaticResource ComposerPillButton}" Background="Transparent" Click="MainThinking_Click">
                  <StackPanel Orientation="Horizontal">
                    <local:LucideIcon Icon="zap" Size="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding ModelControlLabel}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="14" FontWeight="Medium" />
                    <local:LucideIcon Icon="chevron-down" Size="12" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="6,1,0,0" />
                  </StackPanel>
                </Button>
                <Popup PlacementTarget="{Binding ElementName=MainThinkingPickerHost}" Placement="Top" VerticalOffset="-8" AllowsTransparency="True" StaysOpen="False" IsOpen="{Binding IsMainThinkingPickerOpen, Mode=TwoWay}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                  <Border Width="344" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="14" Padding="12,10">
                    <StackPanel>
                      <TextBlock Text="{Binding ReasoningText}" Foreground="{DynamicResource TextMuted}" FontSize="14" FontWeight="Medium" Margin="8,0,8,8" />
                      <ItemsControl ItemsSource="{Binding ReasoningOptions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Button Style="{StaticResource ApprovalMenuOptionButton}" Click="ReasoningOption_Click">
                              <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="24" /></Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Regular" />
                                <TextBlock Grid.Column="1" Text="{Binding SelectedMark}" Foreground="{DynamicResource TextPrimary}" FontSize="17" HorizontalAlignment="Center" />
                              </Grid>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <Border Height="1" Background="{DynamicResource PopupDivider}" Margin="8,7" />
                      <TextBlock Text="{Binding ModelText}" Foreground="{DynamicResource TextMuted}" FontSize="13" FontWeight="Medium" Margin="8,0,8,6" />
                      <ItemsControl ItemsSource="{Binding ModelOptions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Button Style="{StaticResource ApprovalMenuOptionButton}" Click="ModelOption_Click">
                              <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /><ColumnDefinition Width="24" /></Grid.ColumnDefinitions>
                                <local:LucideIcon Icon="zap" Size="14" Stroke="#C8C9CE" />
                                <StackPanel Grid.Column="1">
                                  <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Medium" />
                                  <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextDim}" FontSize="11" Margin="0,2,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding SelectedMark}" Foreground="{DynamicResource TextPrimary}" FontSize="17" HorizontalAlignment="Center" />
                              </Grid>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </Popup>
              </Grid>
              <Grid Grid.Column="5" x:Name="MainVoicePickerHost" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                  <Button Style="{StaticResource ComposerIconButton}" Width="30" Height="30" Click="Voice_Click" ToolTip="{Binding VoiceBackendLabel}" AutomationProperties.Name="{Binding VoiceBackendLabel}">
                    <local:LucideIcon Icon="{Binding VoiceButtonLabel}" Size="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" HorizontalAlignment="Center" />
                  </Button>
                  <Button Width="16" Height="30" Style="{StaticResource GhostButton}" Click="VoicePicker_Click" ToolTip="{Binding VoiceModeToolTip}" AutomationProperties.Name="{Binding VoiceModeToolTip}">
                    <local:LucideIcon Icon="chevron-down" Size="11" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" HorizontalAlignment="Center" />
                  </Button>
                </StackPanel>
                <Popup PlacementTarget="{Binding ElementName=MainVoicePickerHost}" Placement="Top" VerticalOffset="-8" AllowsTransparency="True" StaysOpen="False" IsOpen="{Binding IsMainVoicePickerOpen, Mode=TwoWay}" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                  <Border Width="380" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="14" Padding="12">
                    <StackPanel>
                      <TextBlock Text="{Binding VoiceModeTitle}" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold" Margin="8,4,8,8" />
                      <ItemsControl ItemsSource="{Binding VoiceOptions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Button Style="{StaticResource GhostButton}" Click="VoiceOption_Click" Margin="0,0,0,3">
                              <Grid Margin="8,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="58" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Badge}" Foreground="{DynamicResource TextDim}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <StackPanel Grid.Column="1">
                                  <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold" />
                                  <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextDim}" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0" />
                                </StackPanel>
                              </Grid>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </Popup>
              </Grid>
              <Button Grid.Column="6" Style="{StaticResource CodexSendButton}" Width="32" Height="32" Click="Send_Click" ToolTip="{Binding SendButtonToolTip}" AutomationProperties.Name="{Binding SendButtonToolTip}">
                <local:LucideIcon Icon="{Binding SendButtonGlyph}" Size="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
              </Button>
            </Grid>
          </Grid>
        </Border>

        <Grid Margin="0,7,6,0" Visibility="Collapsed">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Grid Grid.Column="0" x:Name="WorkspacePickerHost" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0">
            <Button Style="{StaticResource GhostButton}" Click="ProjectPath_Click" Padding="0">
              <StackPanel Orientation="Horizontal" Margin="0,0,0,0" VerticalAlignment="Center">
                <local:LucideIcon Icon="folder" Size="13" Stroke="{DynamicResource TextDim}" Margin="0,0,6,0" />
                <TextBlock Text="{Binding WorkspaceChipLabel}" Foreground="{DynamicResource TextMuted}" FontSize="12" />
                <local:LucideIcon Icon="chevron-down" Size="12" Stroke="{DynamicResource TextDim}" Margin="6,1,0,0" />
              </StackPanel>
            </Button>

          <Popup PlacementTarget="{Binding ElementName=WorkspacePickerHost}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="8"
                 AllowsTransparency="True"
                 StaysOpen="False"
                 IsOpen="{Binding IsProjectPickerOpen, Mode=TwoWay}"
                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <Border Width="360" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="14" Padding="14">
              <StackPanel>
                <Border Background="{DynamicResource ComposerChipBg}" BorderBrush="{DynamicResource ComposerChipBorder}" BorderThickness="1" CornerRadius="9" Padding="10,7" Margin="0,0,0,10">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="24" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <local:LucideIcon Icon="search" Size="15" Stroke="{DynamicResource TextDim}" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="{Binding ProjectSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}"
                             FontSize="14" />
                  </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding ProjectPickerItems}" Margin="0,0,0,8">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Style="{StaticResource GhostButton}" Click="ProjectChoice_Click" Margin="0,0,0,2">
                        <Grid Margin="8,8">
                          <Grid.ColumnDefinitions><ColumnDefinition Width="26" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                          <local:LucideIcon Icon="folder" Size="14" Stroke="{DynamicResource TextMuted}" VerticalAlignment="Center" />
                          <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Path}" Foreground="{DynamicResource TextDim}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                          </StackPanel>
                          <TextBlock Grid.Column="2" Text="✓" Foreground="{DynamicResource TextMuted}" FontSize="14" VerticalAlignment="Center" Margin="10,0,0,0" />
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border BorderBrush="{DynamicResource PopupDivider}" BorderThickness="0,1,0,0" Margin="6,2,6,8" />

                <Grid x:Name="NewProjectMenuHost" Margin="0,0,0,2">
                  <Button Style="{StaticResource GhostButton}" Click="ProjectNewMenu_Click">
                    <Grid Margin="8,9"><Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <local:LucideIcon Icon="plus" Size="16" Stroke="{DynamicResource TextPrimary}" />
                      <TextBlock Grid.Column="1" Text="{Binding NewProjectText}" Foreground="{DynamicResource TextPrimary}" FontSize="14" />
                      <local:LucideIcon Grid.Column="2" Icon="chevron-right" Size="13" Stroke="{DynamicResource TextDim}" />
                    </Grid>
                  </Button>
                  <Popup PlacementTarget="{Binding ElementName=NewProjectMenuHost}"
                         Placement="Right"
                         HorizontalOffset="8"
                         VerticalOffset="0"
                         AllowsTransparency="True"
                         StaysOpen="False"
                         IsOpen="{Binding IsNewProjectMenuOpen, Mode=TwoWay}"
                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <Border Width="260" Background="{DynamicResource PopupBg}" BorderBrush="{DynamicResource PopupBorder}" BorderThickness="1" CornerRadius="12" Padding="10">
                      <StackPanel>
                        <Button Style="{StaticResource GhostButton}" Click="ProjectCreateNamed_Click" Margin="0,0,0,2">
                          <Grid Margin="8,9"><Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <local:LucideIcon Icon="plus" Size="16" Stroke="{DynamicResource TextPrimary}" />
                            <TextBlock Grid.Column="1" Text="{Binding NewBlankProjectText}" Foreground="{DynamicResource TextPrimary}" FontSize="14" />
                          </Grid>
                        </Button>
                        <Button Style="{StaticResource GhostButton}" Click="ProjectUseFolder_Click">
                          <Grid Margin="8,9"><Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <local:LucideIcon Icon="folder" Size="15" Stroke="{DynamicResource TextMuted}" />
                            <TextBlock Grid.Column="1" Text="{Binding UseExistingFolderText}" Foreground="{DynamicResource TextPrimary}" FontSize="14" />
                          </Grid>
                        </Button>
                      </StackPanel>
                    </Border>
                  </Popup>
                </Grid>
                <Button Style="{StaticResource GhostButton}" Click="ProjectNoProject_Click">
                  <Grid Margin="8,9"><Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <local:LucideIcon Icon="x" Size="15" Stroke="{DynamicResource TextMuted}" />
                    <TextBlock Grid.Column="1" Text="{Binding DefaultChatNoProjectText}" Foreground="{DynamicResource TextPrimary}" FontSize="14" />
                  </Grid>
                </Button>
              </StackPanel>
            </Border>
          </Popup>
        </Grid>


        </Grid>

      </StackPanel>

      <Border Grid.Row="1" Grid.RowSpan="3" Visibility="{Binding SystemContextVisibility}" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="1" Margin="0,0,0,0" ClipToBounds="True">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="12,10,14,12">
          <ScrollViewer.Resources>
            <Style TargetType="{x:Type ScrollBar}">
              <Setter Property="Width" Value="10" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Background="Transparent" Width="{TemplateBinding Width}" Margin="0,7,3,7">
                      <Track x:Name="PART_Track" IsDirectionReversed="True">
                        <Track.DecreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="False" /></Track.DecreaseRepeatButton>
                        <Track.Thumb>
                          <Thumb MinHeight="36" Background="{DynamicResource TextDim}" Focusable="False">
                            <Thumb.Template>
                              <ControlTemplate TargetType="{x:Type Thumb}">
                                <Border Width="4" HorizontalAlignment="Center" Background="{TemplateBinding Background}" CornerRadius="2" Opacity="0.52" />
                              </ControlTemplate>
                            </Thumb.Template>
                          </Thumb>
                        </Track.Thumb>
                        <Track.IncreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="False" /></Track.IncreaseRepeatButton>
                      </Track>
                    </Grid>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ScrollViewer.Resources>
          <ItemsControl ItemsSource="{Binding SystemContextSections}">
