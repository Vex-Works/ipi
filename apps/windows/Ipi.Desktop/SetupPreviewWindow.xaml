<Window x:Class="Ipi.Desktop.SetupPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Ipi.Desktop"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="ipi Setup" Width="860" Height="620" MinWidth="760" MinHeight="540"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="CanResize"
        Background="#EEF1F7" UseLayoutRounding="True" SnapsToDevicePixels="True"
        Icon="Assets/Brand/app/ipi-icon.ico"
        Loaded="SetupPreviewWindow_Loaded">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="42" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>
  <Window.Resources>
    <FontFamily x:Key="SetupSans">Microsoft YaHei UI, Microsoft YaHei, DengXian, Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="SetupCode">Cascadia Mono, Consolas, Microsoft YaHei UI</FontFamily>
    <SolidColorBrush x:Key="SetupBg" Color="#EEF1F7" />
    <SolidColorBrush x:Key="SetupTitleBg" Color="#F4F6FB" />
    <SolidColorBrush x:Key="SetupPanel" Color="#F9FAFE" />
    <SolidColorBrush x:Key="SetupText" Color="#242733" />
    <SolidColorBrush x:Key="SetupMuted" Color="#626A7A" />
    <SolidColorBrush x:Key="SetupDim" Color="#8C95A6" />
    <SolidColorBrush x:Key="SetupLine" Color="#CBD3E6" />
    <SolidColorBrush x:Key="SetupSoftLine" Color="#DDE4F2" />
    <SolidColorBrush x:Key="SetupAccent" Color="#242733" />
    <SolidColorBrush x:Key="SetupAccentHover" Color="#363B4A" />
    <SolidColorBrush x:Key="SetupOk" Color="#3BBE76" />
    <SolidColorBrush x:Key="SetupDanger" Color="#B94B63" />

    <Style TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource SetupSans}" />
      <Setter Property="Foreground" Value="{StaticResource SetupText}" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="FontFamily" Value="{StaticResource SetupSans}" />
      <Setter Property="Foreground" Value="{StaticResource SetupText}" />
      <Setter Property="CaretBrush" Value="{StaticResource SetupAccent}" />
      <Setter Property="SelectionBrush" Value="#B9C8F6" />
    </Style>

    <Style x:Key="SetupButton" TargetType="Button">
      <Setter Property="Height" Value="38" />
      <Setter Property="MinWidth" Value="124" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="{StaticResource SetupAccent}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontFamily" Value="{StaticResource SetupSans}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="9">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Chrome" Property="Background" Value="{StaticResource SetupAccentHover}" /></Trigger>
              <Trigger Property="IsPressed" Value="True"><Setter TargetName="Chrome" Property="Opacity" Value="0.82" /></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource SetupButton}">
      <Setter Property="Background" Value="#E7ECF7" />
      <Setter Property="Foreground" Value="{StaticResource SetupText}" />
      <Setter Property="BorderBrush" Value="#C5CEE2" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="GhostSetupButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Chrome" Property="Background" Value="#E3E8F3" /></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SetupThinScrollBar" TargetType="{x:Type ScrollBar}">
      <Setter Property="Width" Value="8" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type ScrollBar}">
            <Grid Background="Transparent" Width="{TemplateBinding Width}">
              <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="False" /></Track.DecreaseRepeatButton>
                <Track.Thumb>
                  <Thumb MinHeight="42" Background="{StaticResource SetupDim}" Focusable="False">
                    <Thumb.Template>
                      <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="4" HorizontalAlignment="Center" Background="{TemplateBinding Background}" CornerRadius="2" Opacity="0.36" />
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
                <Track.IncreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="False" /></Track.IncreaseRepeatButton>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SetupThinScrollBar}" />

    <Style x:Key="ProviderOptionButton" TargetType="Button">
      <Setter Property="Width" Value="640" />
      <Setter Property="Height" Value="64" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
      <Setter Property="RenderTransform"><Setter.Value><ScaleTransform ScaleX="1" ScaleY="1" /></Setter.Value></Setter>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="HoverLift" Background="{TemplateBinding Background}" CornerRadius="10">
              <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.012" Duration="0:0:0.12" />
                      <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.012" Duration="0:0:0.12" />
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.14" />
                      <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.14" />
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.ExitActions>
              </Trigger>
              <Trigger Property="IsPressed" Value="True"><Setter TargetName="HoverLift" Property="Opacity" Value="0.86" /></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SetupProgressBar" TargetType="{x:Type ProgressBar}">
      <Setter Property="Height" Value="3" />
      <Setter Property="Background" Value="#DDE4F2" />
      <Setter Property="Foreground" Value="{StaticResource SetupAccent}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type ProgressBar}">
            <Border Background="{TemplateBinding Background}" CornerRadius="1.5">
              <Grid x:Name="PART_Track" ClipToBounds="True">
                <Rectangle x:Name="PART_Indicator" HorizontalAlignment="Left" Fill="{TemplateBinding Foreground}" RadiusX="1.5" RadiusY="1.5" />
              </Grid>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border BorderBrush="#C4CCDA" BorderThickness="1" Background="{StaticResource SetupBg}">
    <Grid ClipToBounds="True">
      <Grid.RowDefinitions>
        <RowDefinition Height="42" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="{StaticResource SetupBg}" BorderBrush="{StaticResource SetupSoftLine}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="38" />
            <ColumnDefinition Width="38" />
            <ColumnDefinition Width="38" />
          </Grid.ColumnDefinitions>
          <Image Source="Assets/Brand/export/black/ipi-word-black.png" Height="15" Width="42" Stretch="Uniform" VerticalAlignment="Center" Margin="15,0,0,0" RenderOptions.BitmapScalingMode="NearestNeighbor" />
          <TextBlock Grid.Column="1" Text="Setup" Foreground="{StaticResource SetupMuted}" FontSize="12" VerticalAlignment="Center" Margin="7,0,0,0" />
          <Button Grid.Column="3" Style="{StaticResource GhostSetupButton}" Click="Minimize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"><TextBlock Text="—" Foreground="{StaticResource SetupMuted}" FontSize="14" /></Button>
          <Button Grid.Column="4" Style="{StaticResource GhostSetupButton}" Click="MaximizeRestore_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"><TextBlock Text="□" Foreground="{StaticResource SetupMuted}" FontSize="11" /></Button>
          <Button Grid.Column="5" Style="{StaticResource GhostSetupButton}" Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"><TextBlock Text="×" Foreground="{StaticResource SetupMuted}" FontSize="18" Margin="0,-2,0,0" /></Button>
        </Grid>
      </Border>

      <Grid Grid.Row="1">
        <Grid.Style>
          <Style TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers><DataTrigger Binding="{Binding Screen}" Value="welcome"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
          </Style>
        </Grid.Style>
        <Image Source="Assets/Brand/export/black/ipi-icon-black.png" Width="740" Height="740" Stretch="Uniform" Opacity="0.032" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-230,8" IsHitTestVisible="False" />
        <StackPanel Width="520" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-20,0,0">
          <Image Source="Assets/Brand/export/black/ipi-all-black.png" Width="142" Height="92" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.92" Margin="0,0,0,18" />
          <TextBlock Text="Set up" FontSize="28" FontWeight="SemiBold" TextAlignment="Center" />
          <Border Background="#F7F9FD" BorderBrush="{StaticResource SetupSoftLine}" BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,28,0,0">
            <Grid>
              <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
              <TextBlock Text="Install location" Foreground="{StaticResource SetupMuted}" FontSize="11" FontWeight="SemiBold" Margin="2,0,0,7" />
              <Grid Grid.Row="1">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="88" /></Grid.ColumnDefinitions>
                <TextBox Text="{Binding InstallPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32" Background="Transparent" BorderBrush="{StaticResource SetupSoftLine}" BorderThickness="0" Padding="2,0" VerticalContentAlignment="Center" FontSize="12" />
                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Click="BrowseInstallPath_Click" Content="Browse" Width="80" Height="32" MinWidth="0" FontSize="12" HorizontalAlignment="Right" />
              </Grid>
            </Grid>
          </Border>
          <Button Style="{StaticResource SetupButton}" Click="ShowProgress_Click" HorizontalAlignment="Center" Width="148" Margin="0,26,0,0">
            <StackPanel Orientation="Horizontal"><TextBlock Text="Continue" Foreground="White" FontSize="13" FontWeight="SemiBold" /><TextBlock Text="  →" Foreground="White" FontSize="16" Margin="5,-1,0,0" /></StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <Grid Grid.Row="1">
        <Grid.Style>
          <Style TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers><DataTrigger Binding="{Binding IsInstallScreen}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
          </Style>
        </Grid.Style>
        <Grid.RowDefinitions>
          <RowDefinition Height="70" />
          <RowDefinition Height="*" />
          <RowDefinition Height="58" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{StaticResource SetupSoftLine}" BorderThickness="0,0,0,1" Background="#F7F9FD" Padding="26,0">
          <Grid>
            <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="3" /></Grid.RowDefinitions>
            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <local:LucideIcon Icon="loader" Size="14" Stroke="{StaticResource SetupAccent}" Margin="0,0,10,0" />
                <TextBlock Text="{Binding CurrentStep}" FontSize="13" Foreground="{StaticResource SetupText}" />
              </StackPanel>
              <TextBlock Grid.Column="1" Text="{Binding StepCounter}" FontSize="12" Foreground="{StaticResource SetupDim}" VerticalAlignment="Center" />
            </Grid>
            <ProgressBar Grid.Row="1" Style="{StaticResource SetupProgressBar}" Value="{Binding ProgressPercent, Mode=OneWay}" Maximum="100" VerticalAlignment="Bottom" Visibility="{Binding SetupProgressVisibility}" />
          </Grid>
        </Border>

        <Grid Grid.Row="1">
          <Grid.Style>
            <Style TargetType="Grid">
              <Setter Property="Margin" Value="26,18,26,18" />
              <Style.Triggers><DataTrigger Binding="{Binding ShowDetails}" Value="True"><Setter Property="Margin" Value="26,0,0,0" /></DataTrigger></Style.Triggers>
            </Style>
          </Grid.Style>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="{Binding DetailColumnWidth}" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Width="620" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#F7F9FD" BorderBrush="{StaticResource SetupSoftLine}" BorderThickness="1" CornerRadius="14" Padding="24,22" Visibility="{Binding RuntimeInstallConfirmationVisibility}">
            <Grid>
              <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
              <StackPanel>
                <TextBlock Text="Install Pi runtime" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource SetupText}" />
                <TextBlock Text="Nothing is running yet. Review the local target, then start runtime setup." Foreground="{StaticResource SetupMuted}" FontSize="13" Margin="0,8,0,0" />
              </StackPanel>
              <Grid Grid.Row="1" Margin="0,20,0,22">
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <TextBlock Text="Source" Foreground="{StaticResource SetupDim}" FontSize="12" />
                <TextBlock Grid.Column="1" Text="{Binding RuntimeInstallSource}" Foreground="{StaticResource SetupText}" FontSize="12.5" FontFamily="{StaticResource SetupCode}" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Row="1" Text="Target" Foreground="{StaticResource SetupDim}" FontSize="12" Margin="0,11,0,0" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RuntimeInstallTarget}" Foreground="{StaticResource SetupText}" FontSize="12.5" FontFamily="{StaticResource SetupCode}" TextTrimming="CharacterEllipsis" Margin="0,11,0,0" />
                <TextBlock Grid.Row="2" Text="Agent" Foreground="{StaticResource SetupDim}" FontSize="12" Margin="0,11,0,0" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RuntimeInstallAgentDir}" Foreground="{StaticResource SetupText}" FontSize="12.5" FontFamily="{StaticResource SetupCode}" TextTrimming="CharacterEllipsis" Margin="0,11,0,0" />
              </Grid>
              <Button Grid.Row="2" Style="{StaticResource SetupButton}" Click="InstallRuntime_Click" HorizontalAlignment="Right" Width="144" Height="36" AutomationProperties.Name="Install runtime"><TextBlock Text="Install runtime" Foreground="White" FontSize="12.5" FontWeight="SemiBold" /></Button>
            </Grid>
          </Border>
          <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,12,0" Visibility="{Binding RuntimeChecklistVisibility}">
            <ItemsControl ItemsSource="{Binding Steps}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Height="38" CornerRadius="8" Margin="0,0,12,3">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers><DataTrigger Binding="{Binding State}" Value="active"><Setter Property="Background" Value="{StaticResource SetupPanel}" /></DataTrigger></Style.Triggers>
                      </Style>
                    </Border.Style>
                    <Grid Margin="12,0,12,0">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="24" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="{Binding Glyph}" Foreground="{Binding GlyphBrush}" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding Label}" Foreground="{Binding TextBrush}" FontSize="13" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="{StaticResource SetupDim}" FontSize="11" VerticalAlignment="Center" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
          <Border Grid.Column="1" BorderBrush="{StaticResource SetupSoftLine}" BorderThickness="1,0,0,0" Background="#F7F9FD" Visibility="{Binding DetailsVisibility}">
            <Grid>
              <Grid.RowDefinitions><RowDefinition Height="42" /><RowDefinition Height="*" /></Grid.RowDefinitions>
              <Grid Grid.Row="0" Margin="16,0,16,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="Live output" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource SetupMuted}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding RuntimeModeLabel}" FontSize="11" Foreground="{StaticResource SetupDim}" VerticalAlignment="Center" />
              </Grid>
              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="16,0,16,14">
                <TextBlock Text="{Binding LiveOutput}" FontFamily="{StaticResource SetupCode}" Foreground="#626A7A" FontSize="12" LineHeight="18" TextWrapping="Wrap" />
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>

        <Border Grid.Row="2" BorderBrush="{StaticResource SetupSoftLine}" BorderThickness="0,1,0,0" Background="#F7F9FD" Padding="26,0">
          <Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
              <Button Style="{StaticResource GhostSetupButton}" Click="ToggleDetails_Click" Margin="0,0,22,0">
                <StackPanel Orientation="Horizontal">
                  <local:LucideIcon Icon="file-text" Size="14" Stroke="{StaticResource SetupMuted}" Margin="0,0,8,0" />
                  <TextBlock Text="{Binding DetailsButtonText}" Foreground="{StaticResource SetupMuted}" FontSize="12" />
                </StackPanel>
              </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <Button Style="{StaticResource SecondaryButton}" Content="{Binding CloseButtonText}" Click="Close_Click" Width="86" Height="34" FontSize="12" Margin="0,0,10,0" />
              <Button Style="{StaticResource SetupButton}" Click="InstallRuntime_Click" Width="132" Height="34" FontSize="12" Margin="0,0,10,0" Visibility="{Binding InstallRuntimeButtonVisibility}" AutomationProperties.Name="Install runtime"><TextBlock Text="Install runtime" Foreground="White" FontSize="12" FontWeight="SemiBold" /></Button>
              <Button Style="{StaticResource SetupButton}" Click="Continue_Click" Width="108" Height="34" FontSize="12" Visibility="{Binding ContinueButtonVisibility}" AutomationProperties.Name="Continue">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="Continue" Foreground="White" FontSize="12" FontWeight="SemiBold" />
                  <TextBlock Text="  →" Foreground="White" FontSize="15" Margin="4,-1,0,0" />
                </StackPanel>
              </Button>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>

      <Grid Grid.Row="1">
        <Grid.Style>
          <Style TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers><DataTrigger Binding="{Binding Screen}" Value="provider"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
          </Style>
        </Grid.Style>
        <Image Source="Assets/Brand/export/black/ipi-icon-black.png" Width="760" Height="760" Stretch="Uniform" Opacity="0.026" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-250,0" IsHitTestVisible="False" />
        <Grid Width="700" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-10,0,0">
          <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Choose your model provider" FontSize="26" FontWeight="SemiBold" />
            <TextBlock Text="Select the provider you already use. ipi does not recommend or preselect one; you can add more providers later from Settings." Foreground="{StaticResource SetupMuted}" FontSize="13.5" LineHeight="21" TextWrapping="Wrap" Margin="0,10,0,0" />
          </StackPanel>

          <Border Grid.Row="1" Background="#F7F9FD" BorderBrush="{StaticResource SetupSoftLine}" BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,16" Visibility="{Binding ProviderReadySummaryVisibility}">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
              <Border Width="28" Height="28" CornerRadius="14" Background="#EEF3FF" BorderBrush="{StaticResource SetupSoftLine}" BorderThickness="1">
                <local:ProviderBrandIcon Provider="{Binding ConnectedProviderId}" Label="{Binding ConnectedProviderTitle}" Size="17" Foreground="{StaticResource SetupMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <StackPanel Grid.Column="1">
                <TextBlock Text="Provider connected" Foreground="{StaticResource SetupText}" FontSize="14" FontWeight="SemiBold" />
                <TextBlock Text="{Binding ConnectedProviderDetail}" Foreground="{StaticResource SetupMuted}" FontSize="12.5" Margin="0,5,0,0" TextTrimming="CharacterEllipsis" />
              </StackPanel>
              <TextBlock Grid.Column="2" Text="ready" Foreground="{StaticResource SetupDim}" FontSize="12" VerticalAlignment="Center" />
            </Grid>
          </Border>

          <Grid Grid.Row="2" Visibility="{Binding ProviderGalleryVisibility}">
            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="260" /></Grid.RowDefinitions>
            <Border Height="36" Background="#F7F9FD" BorderBrush="{StaticResource SetupSoftLine}" BorderThickness="1" CornerRadius="9" Padding="12,0" Margin="0,0,0,12">
              <Grid>
                <StackPanel Orientation="Horizontal" IsHitTestVisible="False" VerticalAlignment="Center">
                  <local:LucideIcon Icon="search" Size="14" Stroke="{StaticResource SetupDim}" Margin="0,0,9,0" />
                  <TextBlock Text="Search providers" Foreground="{StaticResource SetupDim}" FontSize="12.5">
                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding ProviderSearchText}" Value=""><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                  </TextBlock>
                </StackPanel>
                <TextBox Text="{Binding ProviderSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Padding="24,0,0,0" VerticalContentAlignment="Center" FontSize="12.5" />
              </Grid>
            </Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding FilteredProviderOptions}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Click="ProviderOption_Click" Style="{StaticResource ProviderOptionButton}" Margin="0,0,0,9">
                      <Border Background="#F7F9FD" BorderBrush="{StaticResource SetupSoftLine}" BorderThickness="1" CornerRadius="10" Padding="14,10" Width="640">
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="22" /></Grid.ColumnDefinitions>
                          <Border Width="28" Height="28" CornerRadius="14" Background="#EEF3FF" BorderBrush="{StaticResource SetupSoftLine}" BorderThickness="1" VerticalAlignment="Center">
                            <local:ProviderBrandIcon Provider="{Binding ProviderId}" Label="{Binding Title}" Size="17" Foreground="{StaticResource SetupMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Border>
                          <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" Foreground="{StaticResource SetupText}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource SetupMuted}" FontSize="12" Margin="0,5,0,0" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                          <TextBlock Grid.Column="2" Text="{Binding Category}" Foreground="{StaticResource SetupDim}" FontSize="11" VerticalAlignment="Center" Margin="12,0,12,0" />
                          <TextBlock Grid.Column="3" Text="›" Foreground="{StaticResource SetupDim}" FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,-2,0,0" />
                        </Grid>
                      </Border>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>

          <Grid Grid.Row="2" Visibility="{Binding ProviderConfigVisibility}">
            <Grid.ColumnDefinitions><ColumnDefinition Width="120" /><ColumnDefinition Width="420" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <Button Width="82" Height="30" HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource GhostSetupButton}" Click="ProviderBack_Click">
              <StackPanel Orientation="Horizontal"><local:LucideIcon Icon="arrow-left" Size="13" Stroke="{StaticResource SetupMuted}" Margin="0,0,6,0" /><TextBlock Text="Back" Foreground="{StaticResource SetupMuted}" FontSize="12.5" /></StackPanel>
            </Button>
            <StackPanel Grid.Column="1">
              <TextBlock Text="{Binding ProviderConfigTitle}" Foreground="{StaticResource SetupText}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
              <TextBlock Text="Provider id" Foreground="{StaticResource SetupMuted}" FontSize="12" Margin="0,0,0,6" />
              <TextBox Text="{Binding NewProviderId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="34" Background="#F7F9FD" BorderBrush="{StaticResource SetupSoftLine}" Foreground="{StaticResource SetupText}" Padding="10,0" VerticalContentAlignment="Center" />
              <TextBlock Text="Base URL" Foreground="{StaticResource SetupMuted}" FontSize="12" Margin="0,12,0,6" />
              <TextBox Text="{Binding NewProviderBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="34" Background="#F7F9FD" BorderBrush="{StaticResource SetupSoftLine}" Foreground="{StaticResource SetupText}" Padding="10,0" VerticalContentAlignment="Center" />
              <TextBlock Text="API type" Foreground="{StaticResource SetupMuted}" FontSize="12" Margin="0,12,0,6" />
              <TextBox Text="{Binding NewProviderApi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="34" Background="#F7F9FD" BorderBrush="{StaticResource SetupSoftLine}" Foreground="{StaticResource SetupText}" Padding="10,0" VerticalContentAlignment="Center" />
              <TextBlock Text="API key reference" Foreground="{StaticResource SetupMuted}" FontSize="12" Margin="0,12,0,6" />
              <TextBox Text="{Binding NewProviderApiKeyRef, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="34" Background="#F7F9FD" BorderBrush="{StaticResource SetupSoftLine}" Foreground="{StaticResource SetupText}" Padding="10,0" VerticalContentAlignment="Center" />
              <TextBlock Text="Model ids, one per line" Foreground="{StaticResource SetupMuted}" FontSize="12" Margin="0,12,0,6" Visibility="{Binding NewProviderModelsVisibility}" />
              <TextBox Text="{Binding NewProviderModelIds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="72" Background="#F7F9FD" BorderBrush="{StaticResource SetupSoftLine}" Foreground="{StaticResource SetupText}" Padding="10,8" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Visibility="{Binding NewProviderModelsVisibility}" />
              <TextBlock Text="{Binding ProviderStatus}" Foreground="{StaticResource SetupMuted}" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0" Visibility="{Binding ProviderStatusVisibility}" />
              <Button Style="{StaticResource SetupButton}" Click="SaveSetupProvider_Click" HorizontalAlignment="Right" Width="132" Height="34" Margin="0,18,0,0" AutomationProperties.Name="Save provider"><TextBlock Text="Save provider" Foreground="White" FontSize="12" FontWeight="SemiBold" /></Button>
            </StackPanel>
            <TextBlock Grid.Column="2" Text="ipi stores provider references in your local Pi models.json. Prefer environment variables for API keys." Foreground="{StaticResource SetupDim}" FontSize="12" LineHeight="18" TextWrapping="Wrap" Margin="24,32,0,0" />
          </Grid>

          <Grid Grid.Row="3" Margin="0,22,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
              <Button Style="{StaticResource GhostSetupButton}" Click="SkipProvider_Click" AutomationProperties.Name="Skip for now"><TextBlock Text="Skip for now" Foreground="{StaticResource SetupMuted}" FontSize="12.5" /></Button>
              <Button Style="{StaticResource GhostSetupButton}" Click="AddAnotherProvider_Click" Margin="22,0,0,0" Visibility="{Binding AddAnotherProviderVisibility}" AutomationProperties.Name="Add another provider"><TextBlock Text="Add another provider" Foreground="{StaticResource SetupMuted}" FontSize="12.5" /></Button>
            </StackPanel>
            <Button Style="{StaticResource SetupButton}" Click="StartIpi_Click" HorizontalAlignment="Right" Width="116" Height="36" Visibility="{Binding StartIpiVisibility}" AutomationProperties.Name="Start ipi">
              <StackPanel Orientation="Horizontal"><TextBlock Text="Start ipi" Foreground="White" FontSize="12" FontWeight="SemiBold" /><TextBlock Text="  →" Foreground="White" FontSize="15" Margin="4,-1,0,0" /></StackPanel>
            </Button>
          </Grid>
        </Grid>
      </Grid>

      <Grid Grid.Row="1">
        <Grid.Style>
          <Style TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers><DataTrigger Binding="{Binding Screen}" Value="failed"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
          </Style>
        </Grid.Style>
        <StackPanel Width="520" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-20,0,0">
          <Image Source="Assets/Brand/export/black/ipi-all-black.png" Width="108" Height="68" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,24" />
          <TextBlock Text="Setup needs attention" Foreground="{StaticResource SetupDanger}" FontSize="26" FontWeight="SemiBold" TextAlignment="Center" />
          <TextBlock Text="Pi runtime initialization failed. Review the log or retry after fixing the environment." Foreground="{StaticResource SetupMuted}" FontSize="14" LineHeight="21" TextAlignment="Center" TextWrapping="Wrap" Margin="0,14,0,0" />
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
            <Button Style="{StaticResource SetupButton}" Click="InstallRuntime_Click" Margin="0,0,12,0"><StackPanel Orientation="Horizontal"><local:LucideIcon Icon="refresh-cw" Size="14" Stroke="White" Margin="0,0,8,0" /><TextBlock Text="Retry" Foreground="White" FontSize="13" FontWeight="SemiBold" /></StackPanel></Button>
            <Button Style="{StaticResource SecondaryButton}" Click="OpenSetupLogs_Click"><StackPanel Orientation="Horizontal"><local:LucideIcon Icon="file-text" Size="14" Stroke="{StaticResource SetupText}" Margin="0,0,8,0" /><TextBlock Text="Open logs" Foreground="{StaticResource SetupText}" FontSize="13" FontWeight="SemiBold" /></StackPanel></Button>
          </StackPanel>
          <TextBlock Text="{Binding SetupLogPath}" Foreground="{StaticResource SetupDim}" FontSize="11" FontFamily="{StaticResource SetupCode}" TextAlignment="Center" Margin="0,24,0,0" />
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
